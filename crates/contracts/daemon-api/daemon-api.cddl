response-ok = "Ok"
response-routed = { "Routed": { "session": session-id } }
response-session-created = { "SessionCreated": { "session": session-id } }
response-drained = { "Drained": [* outbound] }
response-health = { "Health": health-report }
response-stats = { "Stats": stats-report }
telemetry-dump = { "usage": usage-delta, "events": uint64, "healthy": bool, "pending_jobs": uint64, "pending_wakes": uint64, "sessions": uint64, "active": uint64 }
response-telemetry = { "Telemetry": telemetry-dump }
response-sessions = { "Sessions": [* session-info] }
; ----- the uniform WirePage rules (wire v25; see the pagination note in the header) -----
approval-page = { "items": [0*64 approval-info], ? "next": (tstr / null) }
checkpoint-page = { "items": [0*64 checkpoint-info], ? "next": (tstr / null) }
delivery-session-page = { "items": [0*64 session-id], ? "next": (tstr / null) }
model-file-page = { "items": [0*64 model-file], ? "next": (tstr / null) }
