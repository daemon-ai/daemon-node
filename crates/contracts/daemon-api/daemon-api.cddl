response-model-download-started = { "ModelDownloadStarted": download-id }
response-model-downloads = { "ModelDownloads": [* download-status] }
response-model-catalog = { "ModelCatalog": [* installed-model] }
response-model-recommend = { "ModelRecommend": quant-recommendation }
response-model-quantize-started = { "ModelQuantizeStarted": quantize-id }
response-model-quantizes = { "ModelQuantizes": [* quantize-status] }
response-model-inspect = { "ModelInspect": gguf-info }
response-profiles = { "Profiles": [* profile-info] }
response-profile = { "Profile": (profile-spec / null) }   ; ProfileGet returns null on a missing id
response-credentials = { "Credentials": [* credential-info] }
response-models = { "Models": model-page }
response-model-current = { "ModelCurrent": (model-descriptor / null) }
response-provider-catalog = { "ProviderCatalog": [* provider-descriptor] }
response-provider-models = { "ProviderModels": model-page }
response-distribution = { "Distribution": distribution }
response-profile-id = { "ProfileId": tstr }
response-revisions = { "Revisions": revision-page }
response-skill-bundle = { "SkillBundle": skill-bundle }
response-curator-skills = { "CuratorSkills": [* curator-entry] }
response-curator-run = { "CuratorRun": [* curator-change] }
response-auth-begun = { "AuthBegun": auth-begin-response }
response-auth-stepped = { "AuthStepped": auth-step-result }
response-auth-completed = { "AuthCompleted": auth-complete-response }
response-auth-providers = { "AuthProviders": [* auth-provider-info] }
response-checkpoints = { "Checkpoints": checkpoint-page }
response-session-page = { "SessionPage": session-page }
response-session-detail = { "SessionDetail": (session-detail / null) }
response-session-search = { "SessionSearch": [* session-search-hit] }
response-session-recap = { "SessionRecap": (session-recap / null) }
response-agent-catalog = { "AgentCatalog": [* agent-entry] }
response-providers = { "Providers": [* provider-info] }
response-tools = { "Tools": [* tool-info] }
response-commands = { "Commands": [* command-spec] }
response-command-output = { "CommandOutput": command-output }
response-config = { "Config": node-config-view }
gateway-status = { "enabled": bool, "addr": (tstr / null), "listening": bool, "last_error": (tstr / null) }
response-gateway-status = { "GatewayStatus": gateway-status }
response-caps = { "Caps": caps-report }
response-cron-jobs = { "CronJobs": [* cron-job] }
response-cron-id = { "CronId": tstr }
response-cron-runs = { "CronRuns": [* cron-run] }
response-cron-suggestions = { "CronSuggestions": [* cron-suggestion] }
response-chat-routes = { "ChatRoutes": chat-route-page }
response-chat-route = { "ChatRoute": (chat-route / null) }
response-rooms = { "Rooms": room-page }
response-adapters = { "Adapters": [* adapter-info] }
response-transport-instances = { "TransportInstances": [* transport-instance-info] }
