request-contact-set-alias = { "ContactSetAlias": { "transport": transport-id, "contact": contact-info, ? "alias": (tstr / null) } }
request-contact-action-menu = { "ContactActionMenu": { "transport": transport-id, "contact": contact-info } }
request-directory-search = { "DirectorySearch": { "transport": transport-id, ? "query": (tstr / null) } }
request-roster-list = { "RosterList": { "transport": transport-id, ? "after": (tstr / null) } }
request-roster-add = { "RosterAdd": { "transport": transport-id, "contact": contact-info } }
request-roster-update = { "RosterUpdate": { "transport": transport-id, "contact": contact-info } }
request-roster-remove = { "RosterRemove": { "transport": transport-id, "contact": contact-info } }
