; ----- multiplexed / server-streaming socket envelope (wire L0; daemon-sync-protocol-spec.md §2) ---
; Wraps api-request/api-response so one connection carries many correlated exchanges, with
; server-push (Item/End) for streaming requests. These are NOT zcbor entry types (the vendored client
; codec hand-codes this tiny envelope and the generated codec stays scoped to api-request/-response);
; they are here as the authoritative schema + cddl-cat conformance target. The legacy bare
; api-request / api-response path (a connection that sends no Hello) stays valid.
; The client and server `Hello` differ: the server's additionally lists the SASL `auth_mechanisms`
; it offers (empty on an unauthenticated/local-trust node). Auth byte payloads are plain `Vec<u8>`
; (no serde_bytes), so they encode as a CBOR array of ints (`[* uint]`), not `bstr`; the envelope is
; not a zcbor entry type, so this is a cddl-cat conformance target only.
wire-hello-c2s = { "Hello": { "wire_version": uint, "features": [* tstr] } }
wire-hello-s2c = { "Hello": { "wire_version": uint, "features": [* tstr], "auth_mechanisms": [* tstr] } }
wire-call   = { "Call":   { "id": uint64, "req": api-request } }
wire-open   = { "Open":   { "id": uint64, "req": api-request } }
wire-cancel = { "Cancel": { "id": uint64 } }
wire-auth-start  = { "AuthStart":  { "mechanism": tstr, "initial": [* uint] } }
wire-auth-step   = { "AuthStep":   { "data": [* uint] } }
wire-auth-resume = { "AuthResume": { "token": tstr } }
wire-c2s = wire-hello-c2s
         / wire-call
         / wire-open
         / wire-cancel
         / wire-auth-start
         / wire-auth-step
         / wire-auth-resume

wire-reply = { "Reply": { "id": uint64, "res": api-response } }
wire-item  = { "Item":  { "id": uint64, "res": api-response } }
wire-end   = { "End":   { "id": uint64, "error": (api-error / null) } }
wire-reset = { "Reset": { "id": uint64, "epoch": uint64, "head_seq": uint64 } }
; The authenticated principal surfaced on AuthOk (wire mirror of daemon_auth::Principal).
principal-view = { "user_id": tstr, "username": tstr, "roles": [* tstr], "capabilities": [* tstr] }
wire-auth-challenge = { "AuthChallenge": { "data": [* uint] } }
wire-auth-ok        = { "AuthOk": { "token": tstr, "principal": principal-view } }
wire-auth-error     = { "AuthError": { "reason": tstr } }
wire-s2c = wire-hello-s2c
         / wire-reply
         / wire-item
         / wire-end
         / wire-reset
         / wire-auth-challenge
         / wire-auth-ok
         / wire-auth-error

; ----- filesystem / workspace surface DTOs (wire v14; daemon-fs-surface-spec.md) -----
fs-root-id-host = { "host": tstr }
fs-root-id-session = { "session": session-id }
fs-root-id-t = fs-root-id-host
             / "workspace"
             / fs-root-id-session
fs-root-kind-t = "host"
               / "workspace"
               / "session"
fs-root = { "id": fs-root-id-t, "label": tstr, "kind": fs-root-kind-t, ? "session": (session-id / null) }
fs-entry-kind-t = "file"
                / "dir"
                / "symlink"
; 64-bit file metadata: mtime_ms is a millisecond epoch (~1.78e12, always > u32) and size is a file
; length (can exceed 4 GiB), so these must be u64 - the explicit range makes the generated zcbor
; codec pick uint64_t (an unconstrained `uint` defaults to uint32_t, which silently overflows on a
; real mtime). Wire-compatible: ciborium already encodes the Rust u64 as a CBOR uint.
uint64 = 0..18446744073709551615
fs-entry = { "name": tstr, "path": tstr, "kind": fs-entry-kind-t, "size": uint64, "mtime_ms": uint64, ? "ignored": bool }
; One fs_list page (the uniform WirePage over fs-entry, wire v24/v25): bounded at 64 items per
; response; `next` is the last entry's `path`, passed back as the request's `after` to resume
; (absent/null => last page).
fs-list-page = { "items": [0*64 fs-entry], ? "next": (tstr / null) }
fs-revision = { "mtime_ms": uint64, "size": uint64 }
fs-content = { "bytes": byte-array, "revision": fs-revision, ? "truncated": bool, ? "blob_ref": (blob-ref / null) }
fs-search-query = { "query": tstr, ? "regex": bool, ? "case_sensitive": bool, ? "max_results": uint, ? "page": uint }
fs-search-hit = { "path": tstr, "line": uint, "col": uint, "preview": tstr }
fs-search-page = { "hits": [0*64 fs-search-hit], ? "has_more": bool }
fs-change-kind-t = "created"
                 / "modified"
                 / "removed"
fs-change = { "path": tstr, "kind": fs-change-kind-t }
; Cursored, resync-capable (daemon-event-io-spec §5.4.1): head_seq is the live edge; reset=true means
; the reader's after_seq aged out of the ring (events evicted) so the page is not a complete delta and
; the client must re-list to reconcile (the fs analogue of the merged log's Lagged -> Reset).
fs-watch-page-view = { "events": [* fs-change], "next_seq": uint64, "head_seq": uint64, "reset": bool }

; ----- content store DTOs (wire v14; daemon-content-transfer-spec.md) -----
; 32-byte SHA-256, kept as a CBOR array of ints (ContentHash([u8; 32]) serializes as a sequence; the
; fixed 32-byte size is well under the codec's array cap, so it does not need the bstr treatment).
content-hash = [* uint]
byte-range = { "offset": uint64, "len": uint64 }
blob-ref = { "hash": content-hash, "size": uint64, ? "name": (tstr / null), ? "mime": (tstr / null) }
blob-stat = { "size": uint64, "present": bool }
