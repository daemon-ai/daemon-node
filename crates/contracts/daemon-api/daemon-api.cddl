; daemon-api.cddl — the node interface mirror (one surface, many transports).
;
; This is the wire contract every non-in-process transport marshals: the Unix socket, a future
; TCP/JSON-RPC endpoint, and the C FFI buffer pump all carry these CBOR shapes. The in-process
; transport calls the Rust trait directly and skips this encoding. Encoding is deterministic CBOR
; (serde/ciborium, externally-tagged enums). `wire_version` (daemon-common WireVersion::CURRENT)
; governs evolution; bump it on any breaking change to a shape below.

; Note: rule names ending in `-t` are disambiguated from a same-named map member.
; zcbor derives a coder identifier `<map>_<member>` for a map entry, which would collide
; with a sibling rule named `<map>-<member>` (e.g. map `origin`.`scope` vs rule
; `origin-scope`). The `-t` suffix only affects generated C identifiers; CDDL rule names are
; local and never appear on the wire, so the encoding is unchanged.
;
kv-pair = [k: tstr, v: tstr]
; Variable-length opaque byte payloads (file/blob content, opaque event/meta `body` blobs) are
; CBOR byte strings: the Rust fields carry `#[serde(with = "serde_bytes")]` so ciborium emits a
; `bstr`, which the generated zcbor codec decodes as an unbounded `zcbor_string` (no array element
; cap) - the fix that lets arbitrary file sizes round-trip. Fixed 32-byte hashes stay arrays
; (`content-hash`, below) since they are small and `ContentHash([u8; 32])` serializes as a sequence.
byte-array = bstr
wire_version = uint                 ; daemon-common WireVersion (current = 32)

; ----- uniform wire pagination (wire v25) -----
; Every list op that can exceed the client codec's fixed 64-element array buffers is paginated
; with ONE mechanism: the response is a page rule of the shape
;   x-page = { "items": [0*64 x], ? "next": (tstr / null) }
; (the Rust generic `WirePage<T>`), and the request carries a matching optional resume cursor
; `? "after": (tstr / null)` — pass the previous page's `next` back to resume; absent/null `next`
; means the last page. The per-payload page rules live next to their response rules below
; (fs-list-page, conv-page, model-page, model-file-page, checkpoint-page, approval-page,
; revision-page, chat-route-page, delivery-session-page, room-page); tree-report carries its
; page cursor inline (`root` rides every page). The remaining list ops (profiles, credentials,
; commands, cron, adapters, roles, health, ...) are BOUND-ONLY: small, operator-scale sets that
; stay under the 64-element decode cap without a cursor — they adopt the same page recipe if one
; ever outgrows it.

; ----- identifiers (daemon-common newtypes; encoded as text) -----
session-id  = tstr
unit-id     = tstr
req-id      = uint64
job-id      = tstr
profile-ref = tstr
trace-id    = uint64   ; daemon-common TraceId (newtype over u64, serialized transparently)

; ----- usage (daemon-common UsageDelta) -----
usage-delta = {
  "input_tokens": uint64,
  "output_tokens": uint64,
  "api_calls": uint,
  "cache_read_tokens": uint64,
  "cache_write_tokens": uint64,
  "reasoning_tokens": uint64,
  "cost_micros": uint64,
}

; ----- §17 protocol shapes (daemon-protocol; summarized) -----
; the detached-delegation completion-notice provenance (wire v29): set only on the notice turn the
; node injects when a background child finishes, so a client chip-links the turn to the delegation
; card (the spawning orchestrate call's call_id) and the child unit. The engine ignores it.
completion-notice-ref = { "child": session-id, ? "call_id": (tstr / null) }
user-msg = { "text": tstr, ? "attachments": [* blob-ref], ? "notice": (completion-notice-ref / null) }   ; attachments wire v14 (content-transfer Phase 2b); notice wire v29

agent-command-start-turn = { "StartTurn": { "input": user-msg, "request_id": req-id } }
agent-command-steer = { "Steer": { "text": tstr, "request_id": req-id } }
agent-command-observe = { "Observe": { "input": user-msg, "request_id": req-id } }
agent-command-interrupt = { "Interrupt": { "reason": (tstr / null) } }
agent-command-snapshot = { "Snapshot": { "request_id": req-id } }
agent-command-rewind-to = { "RewindTo": { "anchor": rewind-anchor, "request_id": req-id } }
agent-command = agent-command-start-turn
              / agent-command-steer
              / agent-command-observe
              / agent-command-interrupt
              / agent-command-snapshot
              / agent-command-rewind-to
              / "Shutdown"

; ----- conversation-rewind anchor (daemon-protocol RewindAnchor; wire v13) -----
rewind-anchor-user-turn = { "UserTurn": { "ordinal": uint64 } }
rewind-anchor-reply-after = { "ReplyAfter": { "ordinal": uint64 } }
rewind-anchor-cursor = { "Cursor": { "seq": uint64 } }
rewind-anchor = rewind-anchor-user-turn
              / rewind-anchor-reply-after
              / rewind-anchor-cursor

; ----- read-only conversation projection (Snapshot event body) -----
conv-turn-view = {
  "role": tstr,                       ; "user" / "assistant" / "tool"
  "text": tstr,
  "tools": [* tstr],
}

; Wire-bounded (v25): the engine projects only the LAST 64 turns (scroll-back is the durable
; journal's job); waiting_for is capped under the same bound.
conv-view = {
  "epoch": uint64,
  "turns": [0*64 conv-turn-view],
  "waiting_for": [0*64 tstr],
}

; An opaque structured payload a brain (or foreign-agent adapter) attaches for a rich consumer (a
; transcript GUI). Opaque to the daemon: `kind` is a renderer discriminator (a tool name, or a
; reserved kind such as "ansi-stream" / "pty"); `body` is the encoded payload (CBOR by convention).
tool-detail = { "kind": tstr, "body": byte-array }

tool-call-view   = { "call_id": tstr, "name": tstr, "args_summary": tstr, ? "detail": (tool-detail / null) }
tool-result-view = { "call_id": tstr, "ok": bool, "summary": tstr, ? "detail": (tool-detail / null) }

agent-event-turn-started = { "TurnStarted": { "seq": uint64, "trigger": turn-trigger } }
agent-event-text-delta = { "TextDelta": { "seq": uint64, "text": tstr } }
agent-event-reasoning-delta = { "ReasoningDelta": { "seq": uint64, "text": tstr } }
agent-event-content-delta = { "ContentDelta": { "seq": uint64, "kind": tstr, "body": byte-array } }
agent-event-tool-started = { "ToolStarted": { "seq": uint64, "call": tool-call-view } }
agent-event-tool-finished = { "ToolFinished": { "seq": uint64, "result": tool-result-view } }
agent-event-usage = { "Usage": { "seq": uint64, "delta": usage-delta } }
context-status = { "used_tokens": uint64, "max_tokens": (uint64 / null), "budget_tokens": (uint64 / null), "compacted": bool, "dropped_turns": uint }
agent-event-context = { "Context": { "seq": uint64, "status": context-status } }
agent-event-rate-limit = { "RateLimit": { "seq": uint64, "snapshot": rate-limit-snapshot } }
agent-event-turn-finished = { "TurnFinished": { "seq": uint64, "summary": turn-summary } }
agent-event-error = { "Error": { "seq": uint64, "failure": tstr } }
agent-event-steered = { "Steered": { "seq": uint64, "request_id": req-id, "accepted": bool } }
agent-event-snapshot = { "Snapshot": { "seq": uint64, "request_id": req-id, "view": conv-view } }
agent-event-rewound = { "Rewound": { "seq": uint64, "request_id": req-id, "to_cursor": uint64, "epoch": uint64 } }
agent-event = agent-event-turn-started
            / agent-event-text-delta
            / agent-event-reasoning-delta
            / agent-event-content-delta
            / agent-event-tool-started
            / agent-event-tool-finished
            / agent-event-usage
            / agent-event-context
            / agent-event-rate-limit
            / agent-event-turn-finished
            / agent-event-error
            / agent-event-steered
            / agent-event-snapshot
            / agent-event-rewound

; ----- concrete event payloads (tightened from `any`; Rust is authoritative) -----
completion-source-process = { "Process": job-id }
completion-source-delegation = { "Delegation": job-id }
completion-source = completion-source-process / completion-source-delegation
turn-trigger-background = { "BackgroundCompletion": { "source": completion-source } }
turn-trigger-scheduled = { "Scheduled": { "job": job-id } }
turn-trigger = "User" / "Steer" / turn-trigger-background / turn-trigger-scheduled
end-reason = "Completed" / "Suspended" / "Interrupted" / "BudgetExhausted" / "NoProgress" / "Failed"
; foreign-agent failure (wire v30, C6): a structured cause carried on a terminal turn-summary when a
; foreign child dies mid-turn (its stdout closes), so a client renders a crash instead of hanging.
foreign-stage = "Spawn" / "Handshake" / "Turn" / "Unknown"
foreign-failure = { "stage": foreign-stage, ? "agent": (tstr / null) }
turn-summary = { "end_reason": end-reason, "final_text": (tstr / null), "usage": usage-delta, ? "failure": (foreign-failure / null) }
rate-limit-snapshot = { "remaining": (uint64 / null), "limit": (uint64 / null), "reset_ms": (uint64 / null) }

; ----- concrete host-request / host-response payloads (tightened from `any`) -----
budget = { "tokens": (uint64 / null), "wall_ms": (uint64 / null) }
spawn-seed = "FromConversation"
spawn-spec = { "kind": tstr, "seed": spawn-seed }
host-request-kind-approval = { "Approval": { "prompt": tstr, ? "allow_permanent_offered": bool } }
host-request-kind-input = { "Input": { "prompt": tstr } }
host-request-kind-choice = { "Choice": { "prompt": tstr, "options": [* tstr] } }
host-request-kind-delegate = { "Delegate": { "label": tstr, "budget": budget } }
host-request-kind-spawn = { "Spawn": { "spec": spawn-spec } }
host-request-kind-t = host-request-kind-approval
                  / host-request-kind-input
                  / host-request-kind-choice
                  / host-request-kind-delegate
                  / host-request-kind-spawn
; v29: the optional `reason` is an operator justification — meaningful on a deny, where the engine
; injects it as the gated tool's error content so the model can adapt its next attempt.
host-response-body-approved = { "Approved": { "approved": bool, ? "allow_permanent": bool, ? "reason": (tstr / null) } }
host-response-body-input = { "Input": tstr }
host-response-body-chosen = { "Chosen": uint }
host-response-body-delegated = { "Delegated": job-id }
host-response-body-spawned = { "Spawned": session-id }
host-response-body-deferred = { "Deferred": job-id }
host-response-body-t = host-response-body-approved
                   / host-response-body-input
                   / host-response-body-chosen
                   / host-response-body-delegated
                   / host-response-body-spawned
                   / host-response-body-deferred

host-request  = { "request_id": req-id, "kind": host-request-kind-t }
host-response = { "request_id": req-id, "body": host-response-body-t }

outbound-event = { "Event": agent-event }
outbound-request = { "Request": host-request }
outbound = outbound-event
         / outbound-request

; ----- report DTOs -----
service-health = {
  "name": tstr,
  "ok": bool,
  "restarts": uint,
  "detail": (tstr / null),
}

health-report = {
  "all_ok": bool,
  "services": [* service-health],
}

stats-report = {
  "pending_jobs": uint64,
  "pending_wakes": uint64,
  "sessions": uint64,
  "active": uint64,
  "usage": usage-delta,
}

session-state-suspended = { "Suspended": { "job_id": job-id } }
session-state = "Active"
              / session-state-suspended
              / "Ready"
              / "Completed"
              / "Unknown"

; ----- GUI roster identity/hierarchy (wire v14, additive) -----
; Whether a session is owned by the durable (control surface) or live-interactive (session surface)
; lifecycle; the unified roster surfaces both. `session-role` is the inbox/tree taxonomy: only
; `Primary` is listed in the `TopLevel` roster scope; children are reached by walking the tree.
lifecycle    = "Durable" / "Live"
session-role = "Primary"
             / "ManagedChild"
             / "EphemeralSubagent"

session-info = {
  "session": session-id,
  "state": session-state,
  ? "rewindable": bool,                 ; default true (daemon-core sessions truncate; foreign do not)
  ? "bound_profile": (profile-ref / null),
  ? "title": (tstr / null),
  ? "last_activity_ms": (uint64 / null),
  ? "lifecycle": lifecycle,             ; default "Durable"
  ? "role": session-role,               ; default "Primary"
  ? "parent": (session-id / null),
  ? "pinned": bool,                     ; default false (operator-pinned, sorts first)
  ? "archived": bool,                   ; default false (excluded from default scopes)
}

; The scoped roster query (ControlApi::sessions_query). `TopLevel` is the inbox (Primary only).
session-scope-by-profile = { "ByProfile": profile-ref }
session-scope-by-transport = { "ByTransport": transport-id }
session-scope = "TopLevel"
              / session-scope-by-profile
              / session-scope-by-transport
              / "Archived"
              / "All"

; A partial update to a session's roster metadata (rename/pin/archive). Each `null`/absent field is
; a leave-unchanged; a non-null `title` sets it. (`title` is `Option<Option<String>>` in Rust; the
; outer/inner `None` both encode as CBOR null, so the wire shape is `tstr / null`.)
session-meta-patch = {
  ? "title": (tstr / null),
  ? "pinned": (bool / null),
  ? "archived": (bool / null),
}

session-query = {
  ? "scope": session-scope,             ; default "TopLevel"
  ? "after": (session-id / null),       ; exclusive cursor (last id of previous page)
  ? "limit": uint,                      ; 0 = server default
  ? "since_rev": (uint64 / null),         ; L4: delta read past this roster revision (null = full page)
}

session-page = {
  "sessions": [0*64 session-info],
  ? "next_cursor": (session-id / null), ; null => last page
  "rev": uint64,                          ; L4: the roster revision this page reflects
  ? "removed": [0*64 session-id],       ; L4: ids removed since since_rev (delta reads only)
}

; One session's full detail (the detail-pane round-trip).
session-detail = {
  "info": session-info,
  ? "overlay": (session-overlay / null),
  ? "model": (tstr / null),
  ? "delivery_targets": [* delivery-target],
  ? "children": [* session-id],
  ? "checkpoints": uint,
  ? "engine": engine-selector,
  ? "foreign_backend": foreign-backend,
  ? "model_selector": (model-selector / null),
}

; A resident foreign (ACP) session's advertised Model selector, surfaced as live session state
; (Phase 3): the option id, the current value, and the offered choices (flattened across groups).
; Only present for a foreign session whose agent advertises a Model config option.
model-choice = { "id": tstr, "label": tstr }
model-selector = { "option_id": tstr, "current": tstr, "choices": [* model-choice] }

session-search-hit = { "session": session-id, "title": tstr, "snippet": tstr }

; A pure-local recap of a session's recent activity (SessionRecap; no LLM call): total scope
; counts over the whole conversation, plus top tools / recent files / last ask+reply from the
; recent-activity window (the node caps both lists at 5; wire-unbounded so the schema stays a
; superset of every producer).
session-recap = {
  "title": (tstr / null),
  "user_turns": uint,
  "assistant_turns": uint,
  "tool_results": uint,
  "top_tools": [* [name: tstr, count: uint]],
  "files_touched": [* tstr],
  "last_ask": (tstr / null),
  "last_reply": (tstr / null),
}

; A recorded §12 tool checkpoint (rewind point). `turn_ordinal`/`cursor` correlate a workspace
; checkpoint with the conversation rewind anchor / merged-log position when the ledger carries them.
checkpoint-info = {
  "id": tstr,
  "session": session-id,
  "tool": tstr,
  "created_unix": uint64,
  ? "turn_ordinal": (uint64 / null),
  ? "cursor": (uint64 / null),
}

fleet-report = {
  "children": [* unit-id],
  "usage": usage-delta,
}

; ----- §12 edit-approval (runtime control, wire v5) -----
; The per-session edit-approval session mode a caller selects (SetSessionMode); maps onto daemon-core
; ApprovalPolicy. A parked approval (durable HITL) is listed via ApprovalsPending and answered via
; ApprovalDecide; `request_id` is the opaque parked-request handle.
approval-mode = "ask"
              / "accept_edits"
              / "auto_allow"
              / "deny"

; ----- per-session overlay (profiles + session overlay, wire v9) -----
; The unified per-session override layered on the bound profile at engine construction. Persisted as
; host-level session metadata, so a switch is restored on rehydration. Unset fields inherit the
; profile. `tool_allowlist` is a tri-state: inherit the profile's allowlist, override to the full
; node toolset, or override to an explicit list. `provider` is the opaque provider-selector.
tools-override-allowlist = { "allowlist": [* tstr] }
tools-override = "inherit"
               / "full_toolset"
               / tools-override-allowlist

; `workspace` selects the session's workspace root binding (wire v14): inherit the node default
; (isolated per-session sandbox) when absent, or bind in-place to an operator-specified directory.
workspace-binding-bound = { "bound": tstr }
workspace-binding = "isolated"
                  / workspace-binding-bound

session-overlay = {
  ? "model": (tstr / null),
  ? "provider": (provider-selector / null),
  ? "tool_allowlist": tools-override,
  ? "approval_mode": (approval-mode / null),
  ? "workspace": (workspace-binding / null),
}

approval-info = {
  "session": session-id,
  "request_id": tstr,
  "prompt": tstr,
  ? "path": (tstr / null),
  ; fingerprint (wire v28): the §12 exec-approval command fingerprint (lowercase-hex sha256 of the
  ; resolved (abs-binary, argv, env-delta, cwd, exec-surface) tuple), promoted from the prompt string
  ; to a structured field for the operator display. null for non-command approvals (fs edits) and
  ; pre-v28 rows. Enforcement stays snapshot-side (daemon-core).
  ? "fingerprint": (tstr / null),
  ; detail (wire v30): a node-computed structured detail for the gated call — an fs/edit approval
  ; attaches a unified diff (tool-detail with kind == "fs.diff", JSON body {path, diff}). null for
  ; approvals with no computable detail and pre-v30 rows.
  ? "detail": (tool-detail / null),
}

; one remembered exec-approval fingerprint on a session's allow_permanent allow-list (wire v29;
; fingerprint_list / fingerprint_revoke). `label` (wire v30) is populated from the engine's command
; summary at the allow_permanent decide path when known; `remembered_at_ms` (wire v30) is the unix-ms
; capture time (0 for pre-v30 rows).
remembered-fingerprint = {
  "fingerprint": tstr,
  ? "label": (tstr / null),
  ? "remembered_at_ms": uint64,
}

; ----- tree projection DTOs (the GUI/TUI surface over the management tree) -----
unit-kind = "Engine"
          / "Host"
          / "Orchestrator"

; the declared delegation lifetime (wire v29): the orchestrate-tool vocabulary for a child unit —
; a long-lived managed child vs a transient subagent the reaper may archive.
delegation-lifetime = "Persistent"
                    / "Ephemeral"

unit-state-finished = { "Finished": { "end_reason": tstr } }
unit-state = "Running"
           / unit-state-finished
           / "Unknown"

unit-node = {
  "id": unit-id,
  "kind": unit-kind,
  "state": unit-state,
  "work": (tstr / null),
  "usage": usage-delta,
  "children": [* unit-id],
  ; GUI identity/hierarchy enrichment (wire v14, additive).
  ? "profile": (profile-ref / null),
  ? "session": (session-id / null),
  ? "title": (tstr / null),
  ? "role": (session-role / null),      ; null => Primary
  ; lifetime + engine (wire v29): the delegation chip (server-derived from the role, so clients
  ; never re-implement the role->lifetime rule) + the bound profile's engine selector,
  ; denormalized so a tree render needs no per-node ProfileGet. null => primary / unbound.
  ? "lifetime": (delegation-lifetime / null),
  ? "engine": (engine-selector / null),
}

; Paged (wire v25): `nodes` is served 64 per page in unit-id order; `next` is the resume cursor
; for the tree request's `after` (absent/null => last page). `root` rides every page.
tree-report = {
  "root": (unit-id / null),
  "nodes": [0*64 unit-node],
  ? "next": (tstr / null),
}

; A delegation/subagent lifecycle phase (the Subagent manage-event discriminator).
subagent-phase = "Spawned"
               / "Finished"

manage-event-view-started = { "Started": { "seq": uint64 } }
manage-event-view-progress = { "Progress": { "seq": uint64, "text": (tstr / null) } }
manage-event-view-usage = { "Usage": { "seq": uint64, "delta": usage-delta } }
manage-event-view-finished = { "Finished": { "seq": uint64, "end_reason": tstr, "summary": (tstr / null) } }
manage-event-view-error = { "Error": { "seq": uint64, "message": tstr } }
manage-event-view-subagent = { "Subagent": { "seq": uint64, "child": unit-id, "role": session-role, "phase": subagent-phase, "active_children": uint } }
manage-event-view = manage-event-view-started
                  / manage-event-view-progress
                  / manage-event-view-usage
                  / manage-event-view-finished
                  / manage-event-view-error
                  / manage-event-view-subagent

; ----- unified rewind (wire v14) -----
; Where to rewind a session: a conversation anchor to truncate at, plus optional workspace rollback.
rewind-point = {
  "anchor": rewind-anchor,
  ? "restore_workspace": bool,          ; default false
}

; ----- verifiable journal read DTOs (non-destructive reconnect / scroll-back history) -----
; A finished, coalesced chat block (daemon-protocol TranscriptBlock), already decoded for the
; consumer. Opaque tool `detail` / content `body` ride through as in the live shapes above.
transcript-role  = "Assistant" / "User" / "System"
transcript-block-message = { "Message": { "role": transcript-role, "text": tstr } }
transcript-block-tool-call = { "ToolCall": { "call_id": tstr, "name": tstr, "args_summary": tstr, ? "detail": (tool-detail / null) } }
transcript-block-tool-result = { "ToolResult": { "call_id": tstr, "ok": bool, "summary": tstr, ? "detail": (tool-detail / null) } }
transcript-block-request = { "Request": { "request_id": req-id, "kind": host-request-kind-t } }
transcript-block-content = { "Content": { "kind": tstr, "body": byte-array } }
transcript-block = transcript-block-message
                 / transcript-block-tool-call
                 / transcript-block-tool-result
                 / transcript-block-request
                 / transcript-block-content

journal-record-payload-management = { "Management": { "detail": tstr } }
journal-record-payload-block = { "Block": { "block": transcript-block } }
journal-record-payload-t = journal-record-payload-management
                         / journal-record-payload-block

journal-record = {
  "cursor": uint64,
  "segment": uint64,
  "seq": uint64,
  "epoch": uint64,
  "trace": uint64,
  "kind": tstr,
  "timestamp_ms": uint64,
  "verified": bool,
  "payload": journal-record-payload-t,
}

journal-page-view = {
  "entries": [0*64 journal-record],
  "next_cursor": uint64,
  "head_cursor": uint64,
  "sealed_after": (uint64 / null),
}

; ----- merged live session event log (wire v2: the bidirectional, seq-stamped edge) -----
; One ordered log across BOTH directions: inbound (commands / responses / transport meta) and
; outbound (events / raised host requests). `seq` is one monotonic counter across both directions and
; doubles as the non-destructive subscribe cursor. `disposition` is the cache-safety lever: `Context`
; enters the conversation/prompt; `Transport` is observability-only (never prompt, never journaled).
transport-id = tstr                 ; adapter name: "telegram" / "http" / "mcp" / "engine" / ...

origin-scope-dm = { "Dm": { "user": tstr } }
origin-scope-group = { "Group": { "chat": tstr, "thread": (tstr / null) } }
origin-scope-api = { "Api": { "key": tstr } }
origin-scope-t = origin-scope-dm
               / origin-scope-group
               / origin-scope-api
               / "Internal"

; sender-id (wire v28): the immutable, platform-assigned sender identity (Matrix MXID, etc.),
; the transparent newtype `SenderId(String)`. Carried onto `Origin` for downstream attribution
; only — never an input to session-id derivation. Absent/null on host-internal + pre-v28 origins.
sender-id = tstr
origin = {
  "transport": transport-id,
  "scope": origin-scope-t,
  ? "sender": (sender-id / null),
}

direction   = "Inbound" / "Outbound"
disposition = "Context"
            / "Transport"

session-payload-event = { "Event": agent-event }
session-payload-request = { "Request": host-request }
session-payload-command = { "Command": agent-command }
session-payload-response = { "Response": host-response }
session-payload-meta = { "Meta": { "kind": tstr, "body": byte-array } }
session-payload = session-payload-event
                / session-payload-request
                / session-payload-command
                / session-payload-response
                / session-payload-meta

session-log-entry = {
  "seq": uint64,
  "direction": direction,
  "origin": origin,
  "disposition": disposition,
  "payload": session-payload,
}

log-page-view = {
  "entries": [0*64 session-log-entry],
  "next_seq": uint64,
  "head_seq": uint64,
  "epoch": uint64,                      ; session-activation generation (L2 resync; 0 = first activation)
}

; ----- node-wide event feed (L3 EventsSince): payload-free "what changed out of focus" pointers -----
; wire v30 membership-push deltas.
conv-change = "Added" / "Removed"
membership-change = "Joined" / "Left" / "Invited" / "Kicked" / "Banned"
node-event = node-event-session-advanced
           / node-event-session-meta-changed
           / node-event-roster-changed
           / node-event-fleet-changed
           / node-event-profiles-changed
           / node-event-approval-pending
           / node-event-download-progress
           / node-event-catalog-changed
           / node-event-transport-changed
           / node-event-conversations-changed
           / node-event-membership-changed
           / node-event-contacts-changed
           / node-event-resync-needed
node-event-session-advanced     = { "SessionAdvanced":    { "session": session-id, "epoch": uint64, "head_seq": uint64 } }
node-event-session-meta-changed = { "SessionMetaChanged": { "session": session-id, "rev": uint64 } }
node-event-roster-changed       = { "RosterChanged":      { "rev": uint64 } }
node-event-fleet-changed        = { "FleetChanged":       { "rev": uint64 } }
; v31: the profile set changed (author/edit/delete via operator op or the profile_manage tool) ->
; refetch ProfileList. Like RosterChanged/FleetChanged, a payload-free pointer with a coalescing rev.
node-event-profiles-changed     = { "ProfilesChanged":   { "rev": uint64 } }
node-event-approval-pending     = { "ApprovalPending":    { "session": session-id, "request_id": tstr } }
; v26: byte counters ride the event (throttled byte-level emission node-side).
node-event-download-progress    = { "DownloadProgress":   { "id": download-id, "pct": uint, "state": tstr, "downloaded_bytes": uint64, "total_bytes": uint64 } }
; v26: the installed-model registry changed (download cataloged / model deleted) -> refetch ModelCatalog.
node-event-catalog-changed      = "CatalogChanged"
; v29: a transport instance's connection/presence changed (adapter serve start / teardown / crash),
; carrying the full new state so clients stop navigation-polling TransportInstances.
node-event-transport-changed    = { "TransportChanged":   { "transport": transport-id, "connection": connection-state, ? "presence": presence-state, ? "reason": (disconnect-reason / null), ? "message": (tstr / null), ? "fatal": bool } }
node-event-conversations-changed = { "ConversationsChanged": { "transport": transport-id, "conv": tstr, "change": conv-change } }
node-event-membership-changed   = { "MembershipChanged":  { "transport": transport-id, "conv": tstr, "member": tstr, "change": membership-change, ? "actor": (tstr / null), ? "reason": (tstr / null), "is_self": bool } }
node-event-contacts-changed     = { "ContactsChanged":    { "transport": transport-id } }
node-event-resync-needed        = { "ResyncNeeded":       { "scope": tstr } }
events-page = {
  "events": [0*64 node-event],
  "next_cursor": uint64,                ; pass as the next EventsSince cursor
  "head_cursor": uint64,                ; highest cursor the feed has assigned
}

; ----- outbound delivery targets (§5.4: where a session's replies post) + handover -----
; A session property (seeded from the opening origin), not caller state. Exactly one Primary is in
; force at a time; `Handover` re-points it (demoting the prior Primary to Spectator).
route-addr      = tstr                ; adapter-opaque route handle within a transport
sink-kind       = "Primary" / "Spectator"
delivery-target = { "transport": transport-id, "route": route-addr, "kind": sink-kind }

api-error-unknown-session = { "UnknownSession": tstr }
api-error-unsupported = { "Unsupported": tstr }
api-error-conflict = { "Conflict": tstr }
api-error-unauthenticated = { "Unauthenticated": tstr }
api-error-forbidden = { "Forbidden": tstr }
api-error-other = { "Other": tstr }
api-error = api-error-unknown-session
          / api-error-unsupported
          / api-error-conflict
          / api-error-unauthenticated
          / api-error-forbidden
          / api-error-other

; ----- model-management DTOs (daemon-common; the ModelApi sub-surface) -----
model-id = tstr                       ; content-derived catalog handle
download-id = uint64                  ; numeric job handle (rendered "dl-N")
model-engine = "Llama"
             / "MistralRs"

model-source-hf = { "Hf": { "repo": tstr, "file": (tstr / null), "revision": tstr } }
model-source-local = { "Local": { "path": tstr } }
model-source = model-source-hf
             / model-source-local

model-ref = { "engine": model-engine, "source": model-source }

search-sort = "Trending"
            / "Downloads"
            / "Likes"
            / "Modified"
            / "Created"

search-query = {
  "text": tstr,
  "engine": model-engine,
  "sort": search-sort,
  "page": uint,
  "limit": uint,
}

search-hit = {
  "repo": tstr,
  "author": (tstr / null),
  "downloads": uint64,
  "likes": uint64,
  "num_parameters": (uint64 / null),
  "pipeline_tag": (tstr / null),
  "last_modified": (tstr / null),
  "gated": bool,
  "private": bool,
}

search-page = { "page": uint, "results": [* search-hit], "has_more": bool }

; is_mmproj (wire v27): a vision-projector (mmproj) companion — listed and downloadable, but
; never a chat model (the client badges it; recommendation skips it).
model-file = {
  "path": tstr,
  "size_bytes": uint64,
  "quant": (tstr / null),
  "is_split": bool,
  "is_first_shard": bool,
  "is_mmproj": bool,
}

download-state = "Queued"
               / "Downloading"
               / "Completed"
               / "Paused"
               / "Cancelled"
               / "Failed"

download-status = {
  "id": download-id,
  "model": model-ref,
  "state": download-state,
  "downloaded_bytes": uint64,
  "total_bytes": uint64,
  "files_done": uint,
  "files_total": uint,
  "error": (tstr / null),
}

; mmproj_path (wire v27): the paired vision-projector companion on a *text* record (fetched with
; the download or matched from the local catalog); null/absent for text-only models and for
; projector records themselves.
installed-model = {
  "id": model-id,
  "model": model-ref,
  "display_name": tstr,
  "local_path": tstr,
  "size_bytes": uint64,
  "quant": (tstr / null),
  "installed_at_ms": uint64,
  ? "arch": (tstr / null),
  ? "context_length": (uint / null),
  ? "file_type": (tstr / null),
  ? "mmproj_path": (tstr / null),
  ; sha256 (wire v28): the node-local pinned artifact hash (lowercase hex), read from the
  ; `<local_path>.sha256` provenance sidecar for display. Node-side pin/verify stays authoritative;
  ; null for legacy records cataloged before the pin existed (a re-catalog repins them).
  ? "sha256": (tstr / null),
}

; ----- recommend / quantize / inspect DTOs -----
quantize-id = uint64                  ; numeric job handle (rendered "qz-N")
quantize-state = "Queued"
               / "Preparing"
               / "Quantizing"
               / "Completed"
               / "Failed"

quant-candidate = {
  "quant": tstr,
  "file": (tstr / null),
  "size_bytes": (uint64 / null),
  "fits": bool,
}

quant-recommendation = {
  "engine": model-engine,
  "repo": tstr,
  "file": (tstr / null),
  "quant": tstr,
  "size_bytes": (uint64 / null),
  "budget_bytes": uint64,
  "fits": bool,
  "reason": tstr,
  "candidates": [* quant-candidate],
}

quantize-status = {
  "id": quantize-id,
  "repo": tstr,
  "source_file": tstr,
  "target_quant": tstr,
  "state": quantize-state,
  "output_path": (tstr / null),
  "model_id": (model-id / null),
  "error": (tstr / null),
}

gguf-info = {
  "architecture": (tstr / null),
  "name": (tstr / null),
  "file_type": (tstr / null),
  "context_length": (uint / null),
  "block_count": (uint / null),
  "quantization_version": (uint / null),
  "parameter_count": (uint64 / null),
  "size_bytes": uint64,
}

; ----- foreign-agent discovery/catalog DTOs (wire v14 as acp-*; renamed + protocol-tagged in
; v29; ControlApi::agent_*) -----
; Where a cataloged foreign agent's launch recipe came from. A recipe is either a stdio subprocess
; (`program` + `args` + `env`) or a network `endpoint`; capabilities/version are `initialize`-verified
; for ACP agents (stream-json agents have no handshake, so both stay empty).
agent-source = "Builtin"
             / "Manual"
             / "Endpoint"

; The wire protocol a cataloged agent speaks (wire v29): ACP (JSON-RPC over stdio, the serde
; default — pre-v29 entries without the field decode as "Acp") or Claude-Code-style stream-json
; (NDJSON over the line transport).
agent-protocol = "Acp"
               / "StreamJson"

; The node-derived trust status (wire v32): computed once from installed/protocol/version so every
; client renders the same verdict. "Verified" = installed ACP agent that reported a version at
; `initialize`; "Unverified" = installed but unconfirmed (stream-json, or ACP without a handshake
; version); "NotInstalled" = no candidate found (the serde default — a pre-v32 entry omitting the
; field decodes as "NotInstalled" until the node re-derives).
agent-verification = "Verified"
                   / "Unverified"
                   / "NotInstalled"

agent-recipe = {
  ? "program": (tstr / null),
  ? "args": [* tstr],
  ? "env": [* kv-pair],
  ? "endpoint": (tstr / null),
}

agent-entry = {
  "name": tstr,
  "recipe": agent-recipe,
  "source": agent-source,
  ? "protocol": agent-protocol,
  ? "installed": bool,
  ? "version": (tstr / null),
  ? "capabilities": [* kv-pair],
  ? "verification": agent-verification,
}

; ----- long-tail surface stub DTOs (wire v14; tool-info enriched in v29) -----
; the read-only delegation guardrail caps (wire v29; ControlApi::caps): the EFFECTIVE orchestrate
; ceilings the node enforces, so a client renders "why was this spawn declined" without probing.
; max_composed_profiles / max_ephemeral_per_session (wire v31): the agent-created-agents guardrail
; ceilings — profiles authored per session, and concurrent inline/ephemeral children per session.
; Optional: a pre-v31 encoding omits them and decodes as 0.
caps-report = {
  "orchestrate_max_depth": uint,
  "orchestrate_max_fanout": uint,
  ? "max_composed_profiles": uint,
  ? "max_ephemeral_per_session": uint,
}
provider-info    = { "name": tstr, ? "base_url": (tstr / null), ? "available": bool }
; enabled/requires (wire v29): whether the tool is registered on this node, and — for a disabled
; config-gated surface — the missing config key / credential / build feature a client renders as
; "why is this tool unavailable".
tool-info        = { "name": tstr, ? "description": (tstr / null), "enabled": bool, ? "requires": (tstr / null) }
node-config-view = { "format": tstr, "body": tstr }

; ----- cron / scheduling (wire v15; I15; ControlApi::cron_*) -----
overlap-policy   = "Skip" / "Allow" / "Queue"          ; default "Skip"
catch-up-policy  = "Grace" / "Skip" / "Always"         ; default "Grace"
run-trigger      = "Scheduled" / "Manual"              ; default "Scheduled"
suggestion-status = "Pending" / "Accepted" / "Dismissed" ; default "Pending"
cron-spec = {
  "name": tstr,
  "schedule": tstr,
  ? "target": (tstr / null),
  ? "payload": byte-array,
  ? "enabled": bool,                    ; default true (paused job stays but never fires)
  ? "timezone": (tstr / null),          ; IANA tz for cron exprs; null = node default
  ? "repeat": (uint / null),            ; max fires before auto-delete; null = forever
  ? "jitter_secs": (uint / null),       ; random fire delay 0..=jitter_secs
  ? "overlap": overlap-policy,
  ? "catch_up": catch-up-policy,
  ? "script": (tstr / null),            ; node-scripts-relative path
  ? "no_agent": bool,                   ; run script only, no LLM (requires script)
  ? "context_from": [* tstr],           ; job ids whose last output is injected
  ? "deliver": (tstr / null),           ; delivery routing string; null = store-only
  ? "enabled_toolsets": ([* tstr] / null),
  ? "workdir": (tstr / null),
  ? "model": (tstr / null),
  ? "provider": (tstr / null),
  ? "skills": [* tstr],                 ; (wire v16) skills preloaded before an agent run
  ? "origin": (origin / null),          ; (wire v17) creating chat/session, for deliver="origin"
}
cron-job  = {
  "id": tstr,
  "spec": cron-spec,
  ? "next_fire_unix": (uint64 / null),
  ? "paused": bool,
  ? "last_run_unix": (uint64 / null),
  ? "last_ok": (bool / null),
  ? "last_detail": (tstr / null),
  ? "fire_count": uint,
}
cron-run  = {
  "started_unix": uint64,
  "ok": bool,
  ? "detail": (tstr / null),
  ? "finished_unix": (uint64 / null),
  ? "session": (session-id / null),
  ? "trigger": run-trigger,
}
cron-suggestion = {
  "id": tstr,
  "title": tstr,
  ? "description": tstr,
  ? "source": tstr,
  "spec": cron-spec,
  "dedup_key": tstr,
  ? "status": suggestion-status,
}

; ----- chat->session routing pins (wire v14; I5, §5.9; ControlApi::routing_*) -----
; A resolve-first override of the deterministic origin->session derivation: pin an inbound origin to
; an explicit session (+ optional profile). `isolation` mirrors daemon-protocol IsolationPolicy.
isolation-policy = "PerUser"
                 / "PerChat"
                 / "PerThread"
                 / "Shared"
chat-route = {
  "origin": origin,
  "session": session-id,
  ? "profile": (profile-ref / null),
  ? "isolation": isolation-policy,      ; default "PerThread"
}
room-info = {
  "transport": transport-id,
  "room": tstr,
  ? "name": (tstr / null),
  ? "session": (session-id / null),     ; the pinned session, when one exists
}

; ----- the request/response mirror (1:1 with the interface methods) -----
; `origin` is additive on the v2 wire: absent (old encodings) or null -> the host-local default;
; a value routes through `submit_from` so per-event attribution is recorded on the merged log.
; ----- profile/skill versioning + distribution (wire v6) -----
; `author` provenance: an operator (NodeApi call) or the agent itself (a tool write, labeled).
author-agent = { "agent": tstr }
author = "operator"
       / author-agent
; one revision in an artifact's append-only history (profiles + skills share the mechanism).
revision = {
  "seq": uint64,
  "parent": (uint64 / null),
  "content_hash": content-hash,          ; 32-byte SHA-256 of the snapshot blob (array, see below)
  "author": author,
  "reason": tstr,
  "ts_ms": uint64,
}
; a portable skill bundle: bundle-relative path -> file contents (text; includes SKILL.md).
; signature (wire v28): an optional hex-encoded ed25519 detached signature over the bundle's
; canonical digest (name + category + sorted files), backing the opt-in verify-at-import gate.
; null for unsigned bundles (the default); verification is off unless an operator configures a key.
skill-bundle = { "name": tstr, "category": (tstr / null), "files": { * tstr => tstr }, ? "signature": (tstr / null) }
; a portable profile distribution: the concrete profile-spec plus the profile's local skills;
; credential_ref is kept (a name, not a secret).
distribution = {
  "wire_version": wire_version,
  "profile": profile-spec,
  "skills": [* skill-bundle],
  ? "head_seq": (uint64 / null),
  ? "source": (tstr / null),
}
; the full ProfileSpec (daemon-api profile.rs). serde default + ciborium with no
; skip_serializing_if, so every field is present on the wire (Option fields as null); reuse the
; existing `budget` (BudgetSpec) and `provider-selector`/`bound-account` rules.
engine-tunables = { "model_retry_attempts": (uint / null), "context_budget_tokens": (uint / null), "max_iterations": (uint / null), "tool_result_budget": (uint / null) }
context-engine-sel = "lcm" / "budgeted"
memory-provider-sel = "mnemosyne" / "file" / "none"
; which execution engine a profile's sessions run on (wire v23; the foreign arm renamed
; "Acp" -> "Foreign" in v29, protocol now lives on the catalog entry): the native in-process
; daemon-core engine ("Core", the serde default), or a foreign agent referenced from the node's
; agent catalog BY NAME ONLY. Launch recipes deliberately never travel in profiles — they stay
; node-side and operator-managed (agent_register under existing authz), so a ProfileCreate can
; never smuggle an arbitrary binary spawn. Optional: pre-engine encodings omit it and decode as
; "Core".
engine-foreign-agent = { "agent": tstr }
engine-foreign = { "Foreign": engine-foreign-agent }
engine-selector = "Core"
                / engine-foreign
; how a Foreign-engine profile sources its model backend (wire v30; ForeignBackend). Externally
; tagged struct variants: "AgentNative" steers only the agent's own model (via ACP), "NodeProvider"
; routes the agent through the node gateway to a node provider+model (credential stays node-side).
; Optional on profile-spec/session-detail: a pre-v30 encoding omits it and decodes as
; AgentNative{model:null}. Foreign model selection lives here, not on the Core-only top-level model.
foreign-backend-agent-native = { "AgentNative": { "model": (tstr / null) } }
foreign-backend-node-provider = { "NodeProvider": { "provider": provider-selector, "model": tstr, "credential_ref": (tstr / null) } }
foreign-backend = foreign-backend-agent-native
                / foreign-backend-node-provider
profile-spec = {
  "id": tstr,
  "provider": provider-selector,
  "model": tstr,
  "base_url": (tstr / null),
  "system_prompt": tstr,
  "tool_allowlist": ([* tstr] / null),
  "budget": budget,
  "tunables": engine-tunables,
  "context_engine": context-engine-sel,
  "memory_provider": memory-provider-sel,
  "credential_ref": (tstr / null),
  "fallback_credential_ref": (tstr / null),
  "bound_accounts": [* bound-account],
  ? "engine": engine-selector,
  ? "foreign_backend": foreign-backend,
  ; provenance (wire v31): who authored the profile + the owning agent session id (for an
  ; agent-authored `agent/{session}/{name}` profile; null for operator-authored). Optional: a
  ; pre-provenance encoding omits both and decodes as null/null (treated as operator-authored).
  ? "created_by": (author / null),
  ? "owner": (tstr / null),
}
bound-account = { "transport_instance": tstr, "credential_ref": tstr }
; profile-info provenance (wire v31): mirrors profile-spec's created_by/owner so a client can badge +
; subtree-filter the profile list. Optional (pre-provenance encodings omit both).
profile-info = { "id": tstr, "provider": provider-selector, "model": tstr, "is_active": bool, "bound_accounts": [* bound-account], ? "created_by": (author / null), ? "owner": (tstr / null) }
credential-info = { "profile": tstr, "present": bool, "hint": tstr, ? "label": (tstr / null) }
provider-selector = "mock"
                  / "genai"
                  / "daemon_api"
                  / "llama_cpp"
                  / "mistral_rs"
model-descriptor = { "id": tstr, "provider": provider-selector, ? "display_name": (tstr / null), "context_length": (uint / null), "input_price_micros_per_mtok": (uint64 / null), "output_price_micros_per_mtok": (uint64 / null), "local": bool }
provider-kind-wire = "local" / "cloud" / "daemon_cloud"
; provider-sign-in (wire v30, CON-15): the node advertises interactive sign-in via an auth family.
provider-sign-in = { "family": tstr, "label": tstr }
provider-descriptor = { "id": tstr, "display_name": tstr, "kind": provider-kind-wire, "wire_selector": provider-selector, "requires_key": bool, "supports_model_discovery": bool, "default_base_url": (tstr / null), ? "sign_in": (provider-sign-in / null) }
skill-creator = "agent" / "user" / "bundled"
skill-state = "active" / "stale" / "archived"
skill-usage = { "created_by": skill-creator, "state": skill-state, "pinned": bool, "use_count": uint64, "view_count": uint64, "patch_count": uint64, "created_at_ms": uint64, "last_used_ms": (uint64 / null), "last_viewed_ms": (uint64 / null), "last_patched_ms": (uint64 / null) }
curator-entry = { "name": tstr, "category": (tstr / null), "is_bundled": bool, "usage": skill-usage }
curator-change = { "name": tstr, "from": skill-state, "to": skill-state }
; ----- command catalog (thin-client slash-command surface) -----
; Concrete mirror of daemon-api's CommandSpec/CommandInvocation/CommandOutput. The daemon owns the
; catalog + handlers; clients render menus/autocomplete from command-spec and dispatch
; command-invocation, never modeling commands locally. Unit enums serialize as their variant name;
; #[serde(default)] fields carry no skip_serializing_if, so every field is present on the wire
; (Option fields as null).
command-scope = "Session"
              / "Node"
command-surface = "Cli"
                / "Gui"
                / "Chat"
command-access = "User"
               / "Admin"
command-spec = {
  "name": tstr,
  "aliases": [* tstr],
  "summary": tstr,
  "category": tstr,
  "args_hint": tstr,
  "subcommands": [* tstr],
  "scope": command-scope,
  "surfaces": [* command-surface],
  "side_effecting": bool,
  "confirm": bool,
  "min_access": command-access,
  "source": tstr,
}
command-invocation = {
  "name": tstr,
  "args": tstr,
  "session": (session-id / null),
  "origin": (origin / null),
}
command-output = { "text": tstr, "ephemeral": bool }

; ----- interactive auth (SSO / OAuth2 / token / OTP / QR), wire v13 + multi-step v31 -----
; the client-driven login seam, generalized (v31) into an n-step challenge/response state machine
; modeled on libpurple's request-fields API. The daemon parks a pending flow and drives it via
; auth_step (auth_complete is the single-callback compatibility shape); on completion it writes the
; credential via CredentialStore (and honors any bind).
auth-flow-kind = "MatrixSso"
               / "OAuth2Pkce"
               / "BotToken"
               / "UserToken"
               / "PhoneOtp"
               / "QrPairing"
auth-param-field = { "key": tstr, "label": tstr, "required": bool }
auth-provider-info = { "family": tstr, "flow_kind": auth-flow-kind, "display_name": tstr, "params_schema": [* auth-param-field] }
; one challenge a flow presents at a step — how the client collects the next auth-step-input.
auth-challenge-redirect = { "Redirect": { "authorization_url": tstr } }
auth-challenge-form = { "Form": { "title": tstr, "fields": [* auth-param-field] } }
auth-challenge-qr = { "Qr": { "payload": tstr, "image": (byte-array / null), "poll_interval_ms": uint64 } }
auth-challenge-message = { "Message": { "text": tstr } }
auth-challenge = auth-challenge-redirect
               / auth-challenge-form
               / auth-challenge-qr
               / auth-challenge-message
; the client's response to a challenge (externally-tagged; Poll is the bare unit variant). Each map
; arm is its own named rule (the zcbor idiom — distinct generated decode fns).
auth-step-input-fields = { "Fields": { * tstr => tstr } }
auth-step-input-callback = { "Callback": tstr }
auth-step-input = auth-step-input-fields
                / auth-step-input-callback
                / "Poll"
; optionally bind the freshly-authenticated account to a profile on success.
auth-bind-request = { "profile": tstr, "transport_instance": (transport-id / null), "credential_ref": (tstr / null) }
auth-begin-request = {
  "family": tstr,
  "params": { * tstr => tstr },        ; family-specific (matrix: homeserver, ? idp_id)
  "redirect_uri": tstr,                ; the client-owned capture URI (loopback or custom-scheme)
  ? "bind": (auth-bind-request / null),
}
auth-begin-response = {
  "flow_id": tstr,
  "challenge": auth-challenge,            ; the initial challenge (redirect / form / qr / message)
  "expires_at": uint64,                  ; flow TTL (unix seconds)
}
auth-step-request = { "flow_id": tstr, "input": auth-step-input }
auth-complete-request = { "flow_id": tstr, "callback": tstr }   ; callback: full redirect URL or its query
auth-complete-response = {
  "credential_ref": tstr,
  "account_label": tstr,
  "transport_instance": transport-id,
  "bound_profile": (tstr / null),
}
; the result of advancing a flow one step: the next challenge, or the completed outcome. Each arm is
; its own named rule (the zcbor idiom — distinct generated decode fns).
auth-step-result-challenge = { "Challenge": auth-challenge }
auth-step-result-completed = { "Completed": auth-complete-response }
auth-step-result = auth-step-result-challenge
                 / auth-step-result-completed

; ----- transport-adapter framework + messaging data model (wire v18) -----
account-settings-schema = { ? "fields": [* auth-param-field] }
account-settings-values = { ? "values": { * tstr => tstr } }
adapter-capabilities = {
  "rooms": bool, "direct_messages": bool, "presence": bool,
  "room_enumeration": bool, "file_transfer": bool, "interactive_auth": bool,
}
; policy-entry (wire v30): a node-labeled, node-valued adapter policy a client renders read-only
; (the auth-param-field.label precedent). Matrix reports auto_accept_invites.
policy-entry = { "key": tstr, "label": tstr, "value": tstr }
; Per-verb adapter ops (wire v33): the node reports each MessagingProtocol feature trait's
; supported() probe once on AdapterInfo so clients capability-gate affordances per verb (← the
; libpurple implements_* probes) instead of switching on `family`. Each map is a plain set of
; bool flags; an absent optional field on adapter-info means the adapter does not implement that
; feature trait at all (as opposed to implementing it with every flag false).
conversation-ops = { "create": bool, "join_channel": bool, "leave": bool, "delete": bool, "send": bool, "set_topic": bool, "set_title": bool, "set_description": bool }
membership-ops = { "invite": bool, "remove": bool, "ban": bool, "set_role": bool }
contacts-ops = { "get_profile": bool, "action_menu": bool, "set_alias": bool }
roster-ops = { "list": bool, "add": bool, "update": bool, "remove": bool }
adapter-info = { "family": tstr, "display_name": tstr, "capabilities": adapter-capabilities, ? "account_schema": account-settings-schema, ? "policies": [* policy-entry], ? "conversation_ops": (conversation-ops / null), ? "membership_ops": (membership-ops / null), ? "contacts_ops": (contacts-ops / null), ? "roster_ops": (roster-ops / null), ? "directory": bool }
connection-state = "Offline"
                 / "Connecting"
                 / "Connected"
                 / "Disconnecting"
                 / "Error"
; disconnect-reason (wire v30): the closed Matrix-scoped cause set; the node decides `fatal`.
disconnect-reason = "UserRequested"
                  / "NetworkError"
                  / "AuthenticationFailed"
                  / "ReplacedByOtherClient"
                  / "InvalidSettings"
                  / "CertificateError"
                  / "Other"
presence-state = "Unknown"
               / "Offline"
               / "Available"
               / "Idle"
               / "Away"
               / "Busy"
transport-instance-info = {
  "transport": transport-id, "family": tstr, "display_name": tstr,
  ? "connection": connection-state, ? "presence": presence-state, ? "bound_profile": (profile-ref / null),
  ? "reason": (disconnect-reason / null), ? "message": (tstr / null), ? "fatal": bool,
  ? "enabled": bool, ? "label": (tstr / null),
}
conversation-type = "Unset"
                  / "Dm"
                  / "GroupDm"
                  / "Channel"
                  / "Thread"
member-role = "None"
            / "Voice"
            / "HalfOp"
            / "Op"
            / "Founder"
typing-state = "None"
             / "Typing"
             / "Paused"
presence-primitive-t = "Offline"
                     / "Available"
                     / "Idle"
                     / "Invisible"
                     / "Away"
                     / "DoNotDisturb"
                     / "Streaming"
                     / "OutOfOffice"
presence = { "primitive": presence-primitive-t, ? "message": (tstr / null), ? "emoji": (tstr / null), ? "mobile": bool, ? "idle_since": (uint64 / null) }
contact-permission = "Unset"
                   / "Allow"
                   / "Deny"
contact-info = { "id": tstr, ? "display_name": (tstr / null), ? "presence": presence, ? "permission": contact-permission }
action-menu = { ? "items": [* tstr] }
participant-contact = { "Contact": contact-info }
participant-agent = { "Agent": { "profile": profile-ref, "member": tstr } }
participant = participant-contact
            / participant-agent
conversation-member = {
  "contact": contact-info, ? "alias": (tstr / null), ? "nickname": (tstr / null),
  ? "typing": typing-state, ? "role": member-role, ? "session": (session-id / null),
}
conversation-info = {
  "transport": transport-id, "id": tstr, "kind": conversation-type,
  ? "title": (tstr / null), ? "topic": (tstr / null), ? "description": (tstr / null),
  ? "members": [* conversation-member],
}
create-conversation-details = {
  ? "max_participants": uint, ? "participants": [* contact-info],
  ? "extras_schema": account-settings-schema, ? "extras": account-settings-values,
}
channel-join-details = {
  ? "name": (tstr / null), ? "name_max_length": uint,
  ? "nickname": (tstr / null), ? "nickname_supported": bool, ? "nickname_max_length": uint,
  ? "password": (tstr / null), ? "password_supported": bool, ? "password_max_length": uint,
  ? "extras_schema": account-settings-schema, ? "extras": account-settings-values,
}

request-submit = { "Submit": { "session": session-id, "command": agent-command, ? "origin": (origin / null), ? "profile": (profile-ref / null) } }
request-submit-routed = { "SubmitRouted": { "origin": origin, "command": agent-command } }
; Poll: a DESTRUCTIVE single-consumer drain (FFI/MCP-LCD only; multi-surface uses SessionHistory /
; the cursored log subscribe). See daemon-event-io-spec §5.4.1 (unified cursored-stream contract).
request-poll = { "Poll": { "session": session-id, "max": uint } }
request-respond = { "Respond": { "session": session-id, "response": host-response } }
request-health = "Health"
request-stats = "Stats"
request-telemetry = "Telemetry"
request-sessions = "Sessions"
request-assign = { "Assign": { "session": session-id } }
; SessionCreate: node-authoritative creation of a blank, profile-bound, UN-RUN session (no turn, no
; engine wake). The node mints (`session` absent/null) or accepts the id, binds `profile` (or the
; active default), persists it so it appears in the roster + ByProfile query, emits `RosterChanged`,
; and returns the id via `response-session-created`.
request-session-create = { "SessionCreate": { ? "session": (session-id / null), ? "profile": (profile-ref / null) } }
request-cancel = { "Cancel": { "session": session-id } }
request-fleet = "Fleet"
request-tree = { "Tree": { ? "after": (tstr / null) } }
request-unit = { "Unit": { "unit": unit-id } }
; UnitEvents: a NON-destructive bounded snapshot of a unit's recent management-event views (a read
; over a retained ring), despite the legacy "drain"-style naming. UnitOutbound: a DESTRUCTIVE
; single-consumer drain (FFI/MCP-LCD; multi-surface uses UnitHistory). See daemon-event-io-spec §5.4.1.
request-unit-events = { "UnitEvents": { "unit": unit-id, "max": uint } }
request-unit-outbound = { "UnitOutbound": { "unit": unit-id, "max": uint } }
request-session-history = { "SessionHistory": { "session": session-id, "after_cursor": uint64, "max": uint } }
request-subscribe = { "Subscribe": { "session": session-id, "after_seq": uint64, "max": uint } }
request-events-since = { "EventsSince": { "cursor": uint64, ? "wait_ms": (uint / null) } }
request-delivery-targets = { "DeliveryTargets": { "session": session-id } }
request-delivery-sessions = { "DeliverySessions": { "transport": transport-id, ? "after": (tstr / null) } }
request-handover = { "Handover": { "session": session-id, "target": delivery-target } }
record-meta-args = { "session": session-id, "origin": origin, "kind": tstr, "body": byte-array }
request-record-meta = { "RecordMeta": record-meta-args }
request-unit-history = { "UnitHistory": { "unit": unit-id, "after_cursor": uint64, "max": uint } }
request-pause = { "Pause": { "unit": unit-id } }
request-resume = { "Resume": { "unit": unit-id } }
request-scale = { "Scale": { "unit": unit-id, "n": uint } }
request-verifying-key = "VerifyingKey"
request-set-session-model = { "SetSessionModel": { "session": session-id, "model": tstr, ? "provider": (provider-selector / null) } }
request-set-session-mode = { "SetSessionMode": { "session": session-id, "mode": approval-mode } }
request-set-session-overlay = { "SetSessionOverlay": { "session": session-id, "overlay": session-overlay } }
request-approvals-pending = { "ApprovalsPending": { ? "session": (session-id / null), ? "after": (tstr / null) } }
request-approval-decide = { "ApprovalDecide": { "session": session-id, "request_id": tstr, "allow": bool, ? "allow_permanent": bool, ? "reason": (tstr / null) } }
request-fingerprint-list = { "FingerprintList": { "session": session-id } }
request-fingerprint-revoke = { "FingerprintRevoke": { "session": session-id, "fingerprint": tstr } }
request-profile-list = "ProfileList"
request-profile-get = { "ProfileGet": { "id": tstr } }
request-profile-create = { "ProfileCreate": { "spec": profile-spec } }
request-profile-update = { "ProfileUpdate": { "spec": profile-spec } }
request-profile-delete = { "ProfileDelete": { "id": tstr } }
request-profile-select = { "ProfileSelect": { "id": tstr } }
request-profile-clone = { "ProfileClone": { "source": tstr, "new_id": tstr } }
request-profile-export = { "ProfileExport": { "id": tstr } }
request-profile-import = { "ProfileImport": { "dist": distribution, ? "new_id": (tstr / null) } }
request-profile-history = { "ProfileHistory": { "id": tstr, ? "after": (tstr / null) } }
request-profile-at = { "ProfileAt": { "id": tstr, "seq": uint64 } }
request-profile-revert = { "ProfileRevert": { "id": tstr, "seq": uint64 } }
request-skill-history = { "SkillHistory": { "name": tstr, ? "after": (tstr / null) } }
request-skill-at = { "SkillAt": { "name": tstr, "seq": uint64 } }
request-skill-revert = { "SkillRevert": { "name": tstr, "seq": uint64 } }
request-curator-list = { "CuratorList": { ? "profile": (tstr / null) } }
request-curator-pin = { "CuratorPin": { ? "profile": (tstr / null), "name": tstr } }
request-curator-unpin = { "CuratorUnpin": { ? "profile": (tstr / null), "name": tstr } }
request-curator-archive = { "CuratorArchive": { ? "profile": (tstr / null), "name": tstr } }
request-curator-restore = { "CuratorRestore": { ? "profile": (tstr / null), "name": tstr } }
request-curator-run = { "CuratorRun": { ? "profile": (tstr / null) } }
