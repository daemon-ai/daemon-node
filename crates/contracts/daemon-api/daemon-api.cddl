revision-page = { "items": [0*64 revision], ? "next": (tstr / null) }
chat-route-page = { "items": [0*64 chat-route], ? "next": (tstr / null) }
room-page = { "items": [0*64 room-info], ? "next": (tstr / null) }
conv-page = { "items": [0*64 conversation-info], ? "next": (tstr / null) }
contact-page = { "items": [0*64 contact-info], ? "next": (tstr / null) }
