; daemon-api.cddl — the node interface mirror (one surface, many transports).
;
; This is the wire contract every non-in-process transport marshals: the Unix socket, a future
; TCP/JSON-RPC endpoint, and the C FFI buffer pump all carry these CBOR shapes. The in-process
; transport calls the Rust trait directly and skips this encoding. Encoding is deterministic CBOR
; (serde/ciborium, externally-tagged enums). `wire_version` (daemon-common WireVersion::CURRENT)
; governs evolution; bump it on any breaking change to a shape below.

wire_version = uint                 ; daemon-common WireVersion (current = 17)

; ----- identifiers (daemon-common newtypes; encoded as text) -----
session-id  = tstr
unit-id     = tstr
req-id      = uint
job-id      = tstr
profile-ref = tstr

; ----- usage (daemon-common UsageDelta) -----
usage-delta = {
  input_tokens: uint,
  output_tokens: uint,
  api_calls: uint,
}

; ----- §17 protocol shapes (daemon-protocol; summarized) -----
user-msg = { text: tstr, ? attachments: [* blob-ref] }   ; attachments wire v14 (content-transfer Phase 2b)

agent-command = { "StartTurn": { input: user-msg, request_id: req-id } }
              / { "Steer": { text: tstr, request_id: req-id } }
              / { "Observe": { input: user-msg, request_id: req-id } }   ; wire v8 (context-only append, no turn)
              / { "Interrupt": { reason: (tstr / null) } }
              / { "Snapshot": { request_id: req-id } }
              / { "RewindTo": { anchor: rewind-anchor, request_id: req-id } }  ; wire v14 (conversation rewind)
              / "Shutdown"

; ----- conversation-rewind anchor (daemon-protocol RewindAnchor; wire v13) -----
rewind-anchor = { "UserTurn": { ordinal: uint } }
              / { "ReplyAfter": { ordinal: uint } }
              / { "Cursor": { seq: uint } }

; ----- read-only conversation projection (Snapshot event body) -----
conv-turn-view = {
  role: tstr,                       ; "user" / "assistant" / "tool"
  text: tstr,
  tools: [* tstr],
}

conv-view = {
  epoch: uint,
  turns: [* conv-turn-view],
  waiting_for: [* tstr],
}

; An opaque structured payload a brain (or foreign-agent adapter) attaches for a rich consumer (a
; transcript GUI). Opaque to the daemon: `kind` is a renderer discriminator (a tool name, or a
; reserved kind such as "ansi-stream" / "pty"); `body` is the encoded payload (CBOR by convention).
tool-detail = { kind: tstr, body: bstr }

tool-call-view   = { call_id: tstr, name: tstr, args_summary: tstr, ? detail: (tool-detail / null) }
tool-result-view = { call_id: tstr, ok: bool, summary: tstr, ? detail: (tool-detail / null) }

agent-event = { "TurnStarted": { seq: uint, trigger: any } }
            / { "TextDelta": { seq: uint, text: tstr } }
            / { "ReasoningDelta": { seq: uint, text: tstr } }
            / { "ContentDelta": { seq: uint, kind: tstr, body: bstr } }
            / { "ToolStarted": { seq: uint, call: tool-call-view } }
            / { "ToolFinished": { seq: uint, result: tool-result-view } }
            / { "Usage": { seq: uint, delta: usage-delta } }
            / { "RateLimit": { seq: uint, snapshot: any } }
            / { "TurnFinished": { seq: uint, summary: any } }
            / { "Error": { seq: uint, failure: tstr } }
            / { "Steered": { seq: uint, request_id: req-id, accepted: bool } }
            / { "Snapshot": { seq: uint, request_id: req-id, view: conv-view } }
            / { "Rewound": { seq: uint, request_id: req-id, to_cursor: uint, epoch: uint } }  ; wire v14 (conversation rewind)

host-request  = { request_id: req-id, kind: any }
host-response = { request_id: req-id, body: any }

outbound = { "Event": agent-event }
         / { "Request": host-request }

; ----- report DTOs -----
service-health = {
  name: tstr,
  ok: bool,
  restarts: uint,
  detail: (tstr / null),
}

health-report = {
  all_ok: bool,
  services: [* service-health],
}

stats-report = {
  pending_jobs: uint,
  pending_wakes: uint,
  sessions: uint,
  active: uint,
}

session-state = "Active"
              / { "Suspended": { job_id: job-id } }
              / "Ready"
              / "Completed"
              / "Unknown"

; ----- GUI roster identity/hierarchy (wire v14, additive) -----
; Whether a session is owned by the durable (control surface) or live-interactive (session surface)
; lifecycle; the unified roster surfaces both. `session-role` is the inbox/tree taxonomy: only
; `Primary` is listed in the `TopLevel` roster scope; children are reached by walking the tree.
lifecycle    = "Durable" / "Live"
session-role = "Primary" / "ManagedChild" / "EphemeralSubagent"

session-info = {
  session: session-id,
  state: session-state,
  ? rewindable: bool,                 ; default true (daemon-core sessions truncate; foreign do not)
  ? bound_profile: (profile-ref / null),
  ? title: (tstr / null),
  ? last_activity_ms: (uint / null),
  ? lifecycle: lifecycle,             ; default "Durable"
  ? role: session-role,               ; default "Primary"
  ? parent: (session-id / null),
  ? pinned: bool,                     ; default false (operator-pinned, sorts first)
  ? archived: bool,                   ; default false (excluded from default scopes)
}

; The scoped roster query (ControlApi::sessions_query). `TopLevel` is the inbox (Primary only).
session-scope = "TopLevel"
              / { "ByProfile": profile-ref }
              / { "ByTransport": transport-id }
              / "Archived"
              / "All"

; A partial update to a session's roster metadata (rename/pin/archive). Each `null`/absent field is
; a leave-unchanged; a non-null `title` sets it. (`title` is `Option<Option<String>>` in Rust; the
; outer/inner `None` both encode as CBOR null, so the wire shape is `tstr / null`.)
session-meta-patch = {
  ? title: (tstr / null),
  ? pinned: (bool / null),
  ? archived: (bool / null),
}

session-query = {
  ? scope: session-scope,             ; default "TopLevel"
  ? after: (session-id / null),       ; exclusive cursor (last id of previous page)
  ? limit: uint,                      ; 0 = server default
}

session-page = {
  sessions: [* session-info],
  ? next_cursor: (session-id / null), ; null => last page
}

; One session's full detail (the detail-pane round-trip).
session-detail = {
  info: session-info,
  ? overlay: (session-overlay / null),
  ? model: (tstr / null),
  ? delivery_targets: [* delivery-target],
  ? children: [* session-id],
  ? checkpoints: uint,
}

session-search-hit = { session: session-id, title: tstr, snippet: tstr }

; A recorded §12 tool checkpoint (rewind point). `turn_ordinal`/`cursor` correlate a workspace
; checkpoint with the conversation rewind anchor / merged-log position when the ledger carries them.
checkpoint-info = {
  id: tstr,
  session: session-id,
  tool: tstr,
  created_unix: uint,
  ? turn_ordinal: (uint / null),
  ? cursor: (uint / null),
}

fleet-report = {
  children: [* unit-id],
  usage: usage-delta,
}

; ----- §12 edit-approval (runtime control, wire v5) -----
; The per-session edit-approval session mode a caller selects (SetSessionMode); maps onto daemon-core
; ApprovalPolicy. A parked approval (durable HITL) is listed via ApprovalsPending and answered via
; ApprovalDecide; `request_id` is the opaque parked-request handle.
approval-mode = "ask" / "accept_edits" / "auto_allow" / "deny"

; ----- per-session overlay (profiles + session overlay, wire v9) -----
; The unified per-session override layered on the bound profile at engine construction. Persisted as
; host-level session metadata, so a switch is restored on rehydration. Unset fields inherit the
; profile. `tool_allowlist` is a tri-state: inherit the profile's allowlist, override to the full
; node toolset, or override to an explicit list. `provider` is the opaque provider-selector.
tools-override = "inherit" / "full_toolset" / { "allowlist": [* tstr] }

; `workspace` selects the session's workspace root binding (wire v14): inherit the node default
; (isolated per-session sandbox) when absent, or bind in-place to an operator-specified directory.
workspace-binding = "isolated" / { "bound": tstr }

session-overlay = {
  ? model: (tstr / null),
  ? provider: (any / null),
  ? tool_allowlist: tools-override,
  ? approval_mode: (approval-mode / null),
  ? workspace: (workspace-binding / null),
}

approval-info = {
  session: session-id,
  request_id: tstr,
  prompt: tstr,
  ? path: (tstr / null),
}

; ----- tree projection DTOs (the GUI/TUI surface over the management tree) -----
unit-kind = "Engine" / "Host" / "Orchestrator"

unit-state = "Running"
           / { "Finished": { end_reason: tstr } }
           / "Unknown"

unit-node = {
  id: unit-id,
  kind: unit-kind,
  state: unit-state,
  work: (tstr / null),
  usage: usage-delta,
  children: [* unit-id],
  ; GUI identity/hierarchy enrichment (wire v14, additive).
  ? profile: (profile-ref / null),
  ? session: (session-id / null),
  ? title: (tstr / null),
  ? role: (session-role / null),      ; null => Primary
}

tree-report = {
  root: (unit-id / null),
  nodes: [* unit-node],
}

; A delegation/subagent lifecycle phase (the Subagent manage-event discriminator).
subagent-phase = "Spawned" / "Finished"

manage-event-view = { "Started": { seq: uint } }
                  / { "Progress": { seq: uint, text: (tstr / null) } }
                  / { "Usage": { seq: uint, delta: usage-delta } }
                  / { "Finished": { seq: uint, end_reason: tstr, summary: (tstr / null) } }
                  / { "Error": { seq: uint, message: tstr } }
                  ; subagent spawn/finish churn signal (wire v14)
                  / { "Subagent": { seq: uint, child: unit-id, role: session-role, phase: subagent-phase, active_children: uint } }

; ----- tree-subscribe push stream (wire v14) -----
; A churn-control filter: opt out of ephemeral nodes or coalesce rapid changes into one update per
; window. A `tree-event` is a coalesced whole-tree snapshot or a subagent churn signal.
tree-sub-filter = {
  ? include_ephemeral: bool,          ; default true
  ? coalesce_ms: (uint / null),       ; null => deliver every change
}

tree-event = { "Snapshot": tree-report }
           / { "Subagent": manage-event-view }

; ----- unified rewind (wire v14) -----
; Where to rewind a session: a conversation anchor to truncate at, plus optional workspace rollback.
rewind-point = {
  anchor: rewind-anchor,
  ? restore_workspace: bool,          ; default false
}

; ----- verifiable journal read DTOs (non-destructive reconnect / scroll-back history) -----
; A finished, coalesced chat block (daemon-protocol TranscriptBlock), already decoded for the
; consumer. Opaque tool `detail` / content `body` ride through as in the live shapes above.
transcript-role  = "Assistant" / "User" / "System"
transcript-block = { "Message": { role: transcript-role, text: tstr } }
                 / { "ToolCall": { call_id: tstr, name: tstr, args_summary: tstr, ? detail: (tool-detail / null) } }
                 / { "ToolResult": { call_id: tstr, ok: bool, summary: tstr, ? detail: (tool-detail / null) } }
                 / { "Request": { request_id: req-id, kind: any } }
                 / { "Content": { kind: tstr, body: bstr } }

journal-record-payload = { "Management": { detail: tstr } }
                       / { "Block": { block: transcript-block } }

journal-record = {
  cursor: uint,
  segment: uint,
  seq: uint,
  epoch: uint,
  trace: uint,
  kind: tstr,
  timestamp_ms: uint,
  verified: bool,
  payload: journal-record-payload,
}

journal-page-view = {
  entries: [* journal-record],
  next_cursor: uint,
  head_cursor: uint,
}

; ----- merged live session event log (wire v2: the bidirectional, seq-stamped edge) -----
; One ordered log across BOTH directions: inbound (commands / responses / transport meta) and
; outbound (events / raised host requests). `seq` is one monotonic counter across both directions and
; doubles as the non-destructive subscribe cursor. `disposition` is the cache-safety lever: `Context`
; enters the conversation/prompt; `Transport` is observability-only (never prompt, never journaled).
transport-id = tstr                 ; adapter name: "telegram" / "http" / "mcp" / "engine" / ...

origin-scope = { "Dm": { user: tstr } }
             / { "Group": { chat: tstr, thread: (tstr / null) } }
             / { "Api": { key: tstr } }
             / "Internal"

origin = {
  transport: transport-id,
  scope: origin-scope,
}

direction   = "Inbound" / "Outbound"
disposition = "Context" / "Transport"

session-payload = { "Event": agent-event }
                / { "Request": host-request }
                / { "Command": agent-command }
                / { "Response": host-response }
                / { "Meta": { kind: tstr, body: bstr } }

session-log-entry = {
  seq: uint,
  direction: direction,
  origin: origin,
  disposition: disposition,
  payload: session-payload,
}

log-page-view = {
  entries: [* session-log-entry],
  next_seq: uint,
  head_seq: uint,
}

; ----- outbound delivery targets (§5.4: where a session's replies post) + handover -----
; A session property (seeded from the opening origin), not caller state. Exactly one Primary is in
; force at a time; `Handover` re-points it (demoting the prior Primary to Spectator).
route-addr      = tstr                ; adapter-opaque route handle within a transport
sink-kind       = "Primary" / "Spectator"
delivery-target = { transport: transport-id, route: route-addr, kind: sink-kind }

api-error = { "UnknownSession": tstr }
          / { "Unsupported": tstr }
          / { "Conflict": tstr }
          / { "Other": tstr }

; ----- model-management DTOs (daemon-common; the ModelApi sub-surface) -----
model-id = tstr                       ; content-derived catalog handle
download-id = uint                    ; numeric job handle (rendered "dl-N")
model-engine = "Llama" / "MistralRs"

model-source = { "Hf": { repo: tstr, file: (tstr / null), revision: tstr } }
             / { "Local": { path: tstr } }

model-ref = { engine: model-engine, source: model-source }

search-sort = "Trending" / "Downloads" / "Likes" / "Modified" / "Created"

search-query = {
  text: tstr,
  engine: model-engine,
  sort: search-sort,
  page: uint,
  limit: uint,
}

search-hit = {
  repo: tstr,
  author: (tstr / null),
  downloads: uint,
  likes: uint,
  num_parameters: (uint / null),
  pipeline_tag: (tstr / null),
  last_modified: (tstr / null),
  gated: bool,
  private: bool,
}

search-page = { page: uint, results: [* search-hit], has_more: bool }

model-file = {
  path: tstr,
  size_bytes: uint,
  quant: (tstr / null),
  is_split: bool,
  is_first_shard: bool,
}

download-state = "Queued" / "Downloading" / "Completed" / "Paused" / "Cancelled" / "Failed"

download-status = {
  id: download-id,
  model: model-ref,
  state: download-state,
  downloaded_bytes: uint,
  total_bytes: uint,
  files_done: uint,
  files_total: uint,
  error: (tstr / null),
}

installed-model = {
  id: model-id,
  model: model-ref,
  display_name: tstr,
  local_path: tstr,
  size_bytes: uint,
  quant: (tstr / null),
  installed_at_ms: uint,
  ? arch: (tstr / null),
  ? context_length: (uint / null),
  ? file_type: (tstr / null),
}

; ----- recommend / quantize / inspect DTOs -----
quantize-id = uint                    ; numeric job handle (rendered "qz-N")
quantize-state = "Queued" / "Preparing" / "Quantizing" / "Completed" / "Failed"

quant-candidate = {
  quant: tstr,
  file: (tstr / null),
  size_bytes: (uint / null),
  fits: bool,
}

quant-recommendation = {
  engine: model-engine,
  repo: tstr,
  file: (tstr / null),
  quant: tstr,
  size_bytes: (uint / null),
  budget_bytes: uint,
  fits: bool,
  reason: tstr,
  candidates: [* quant-candidate],
}

quantize-status = {
  id: quantize-id,
  repo: tstr,
  source_file: tstr,
  target_quant: tstr,
  state: quantize-state,
  output_path: (tstr / null),
  model_id: (model-id / null),
  error: (tstr / null),
}

gguf-info = {
  architecture: (tstr / null),
  name: (tstr / null),
  file_type: (tstr / null),
  context_length: (uint / null),
  block_count: (uint / null),
  quantization_version: (uint / null),
  parameter_count: (uint / null),
  size_bytes: uint,
}

; ----- ACP agent discovery/catalog DTOs (wire v14; ControlApi::acp_*) -----
; Where a cataloged ACP agent's launch recipe came from. A recipe is either a stdio subprocess
; (`program` + `args` + `env`) or a network `endpoint`; capabilities/version are `initialize`-verified.
acp-source = "Builtin" / "Manual" / "Endpoint"

acp-recipe = {
  ? program: (tstr / null),
  ? args: [* tstr],
  ? env: [* [tstr, tstr]],
  ? endpoint: (tstr / null),
}

acp-agent-entry = {
  name: tstr,
  recipe: acp-recipe,
  source: acp-source,
  ? installed: bool,
  ? version: (tstr / null),
  ? capabilities: [* [tstr, tstr]],
}

; ----- node log-tail stream DTOs (wire v14; ControlApi::logs) -----
log-filter = { ? min_level: (tstr / null), ? target: (tstr / null) }
log-line   = { ts_ms: uint, level: tstr, target: tstr, message: tstr }

; ----- long-tail surface stub DTOs (wire v14) -----
provider-info    = { name: tstr, ? base_url: (tstr / null), ? available: bool }
tool-info        = { name: tstr, ? description: (tstr / null) }
node-config-view = { format: tstr, body: tstr }

; ----- cron / scheduling (wire v15; I15; ControlApi::cron_*) -----
overlap-policy   = "Skip" / "Allow" / "Queue"          ; default "Skip"
catch-up-policy  = "Grace" / "Skip" / "Always"         ; default "Grace"
run-trigger      = "Scheduled" / "Manual"              ; default "Scheduled"
suggestion-status = "Pending" / "Accepted" / "Dismissed" ; default "Pending"
cron-spec = {
  name: tstr,
  schedule: tstr,
  ? target: (tstr / null),
  ? payload: bstr,
  ? enabled: bool,                    ; default true (paused job stays but never fires)
  ? timezone: (tstr / null),          ; IANA tz for cron exprs; null = node default
  ? repeat: (uint / null),            ; max fires before auto-delete; null = forever
  ? jitter_secs: (uint / null),       ; random fire delay 0..=jitter_secs
  ? overlap: overlap-policy,
  ? catch_up: catch-up-policy,
  ? script: (tstr / null),            ; node-scripts-relative path
  ? no_agent: bool,                   ; run script only, no LLM (requires script)
  ? context_from: [* tstr],           ; job ids whose last output is injected
  ? deliver: (tstr / null),           ; delivery routing string; null = store-only
  ? enabled_toolsets: ([* tstr] / null),
  ? workdir: (tstr / null),
  ? model: (tstr / null),
  ? provider: (tstr / null),
  ? skills: [* tstr],                 ; (wire v16) skills preloaded before an agent run
  ? origin: (origin / null),          ; (wire v17) creating chat/session, for deliver="origin"
}
cron-job  = {
  id: tstr,
  spec: cron-spec,
  ? next_fire_unix: (uint / null),
  ? paused: bool,
  ? last_run_unix: (uint / null),
  ? last_ok: (bool / null),
  ? last_detail: (tstr / null),
  ? fire_count: uint,
}
cron-run  = {
  started_unix: uint,
  ok: bool,
  ? detail: (tstr / null),
  ? finished_unix: (uint / null),
  ? session: (session-id / null),
  ? trigger: run-trigger,
}
cron-suggestion = {
  id: tstr,
  title: tstr,
  ? description: tstr,
  ? source: tstr,
  spec: cron-spec,
  dedup_key: tstr,
  ? status: suggestion-status,
}

; ----- chat->session routing pins (wire v14; I5, §5.9; ControlApi::routing_*) -----
; A resolve-first override of the deterministic origin->session derivation: pin an inbound origin to
; an explicit session (+ optional profile). `isolation` mirrors daemon-protocol IsolationPolicy.
isolation-policy = "PerUser" / "PerChat" / "PerThread" / "Shared"
chat-route = {
  origin: origin,
  session: session-id,
  ? profile: (profile-ref / null),
  ? isolation: isolation-policy,      ; default "PerThread"
}
room-info = {
  transport: transport-id,
  room: tstr,
  ? name: (tstr / null),
  ? session: (session-id / null),     ; the pinned session, when one exists
}

; ----- the request/response mirror (1:1 with the interface methods) -----
; `origin` is additive on the v2 wire: absent (old encodings) or null -> the host-local default;
; a value routes through `submit_from` so per-event attribution is recorded on the merged log.
; ----- profile/skill versioning + distribution (wire v6) -----
; `author` provenance: an operator (NodeApi call) or the agent itself (a tool write, labeled).
author = "operator" / { "agent": tstr }
; one revision in an artifact's append-only history (profiles + skills share the mechanism).
revision = {
  seq: uint,
  parent: (uint / null),
  content_hash: bstr,            ; 32-byte SHA-256 of the snapshot blob
  author: author,
  reason: tstr,
  ts_ms: uint,
}
; a portable skill bundle: bundle-relative path -> file contents (text; includes SKILL.md).
skill-bundle = { name: tstr, category: (tstr / null), files: { * tstr => tstr } }
; a portable profile distribution: the spec (carried as `any` — the Rust ProfileSpec contract) plus
; the profile's local skills; credential_ref is kept (a name, not a secret).
distribution = {
  wire_version: wire_version,
  profile: any,
  skills: [* skill-bundle],
  ? head_seq: (uint / null),
  ? source: (tstr / null),
}
profile-spec = any                       ; full ProfileSpec schema lives in Rust/profile.rs today
profile-info = any
credential-info = any
model-descriptor = any
curator-entry = any
curator-change = any
command-spec = any
command-invocation = any
command-output = any

; ----- interactive auth (SSO / OAuth2), wire v13 (daemon-interactive-auth-spec) -----
; the client-driven, browser-redirect login seam. The client owns the browser + the redirect_uri; the
; daemon parks a pending flow between begin and complete and writes the credential via CredentialStore.
auth-flow-kind = "MatrixSso" / "OAuth2Pkce"
auth-param-field = { key: tstr, label: tstr, required: bool }
auth-provider-info = { family: tstr, flow_kind: auth-flow-kind, display_name: tstr, params_schema: [* auth-param-field] }
; optionally bind the freshly-authenticated account to a profile on success.
auth-bind-request = { profile: tstr, transport_instance: (transport-id / null), credential_ref: (tstr / null) }
auth-begin-request = {
  family: tstr,
  params: { * tstr => tstr },        ; family-specific (matrix: homeserver, ? idp_id)
  redirect_uri: tstr,                ; the client-owned capture URI (loopback or custom-scheme)
  ? bind: (auth-bind-request / null),
}
auth-begin-response = {
  flow_id: tstr,
  authorization_url: tstr,
  redirect_uri: tstr,
  expires_at: uint,                  ; flow TTL (unix seconds)
  flow_kind: auth-flow-kind,
}
auth-complete-request = { flow_id: tstr, callback: tstr }   ; callback: full redirect URL or its query
auth-complete-response = {
  credential_ref: tstr,
  account_label: tstr,
  transport_instance: transport-id,
  bound_profile: (tstr / null),
}

api-request = { "Submit": { session: session-id, command: agent-command, ? origin: (origin / null), ? profile: (profile-ref / null) } }  ; profile wire v14 ("open chat as agent X")
            ; routing (wire v7): submit by origin; the host resolves session + profile + delivery -> Routed
            / { "SubmitRouted": { origin: origin, command: agent-command } }
            / { "Poll": { session: session-id, max: uint } }
            / { "Respond": { session: session-id, response: host-response } }
            / "Health"
            / "Stats"
            / "Telemetry"
            / "Sessions"
            / { "Assign": { session: session-id } }
            / { "Cancel": { session: session-id } }
            / "Fleet"
            / "Tree"
            / { "Unit": { unit: unit-id } }
            / { "UnitEvents": { unit: unit-id, max: uint } }
            / { "UnitOutbound": { unit: unit-id, max: uint } }   ; rich §17 drain -> Drained
            / { "SessionHistory": { session: session-id, after_cursor: uint, max: uint } }
            / { "Subscribe": { session: session-id, after_seq: uint, max: uint } }  ; merged-log cursor read -> LogPage
            / { "DeliveryTargets": { session: session-id } }                        ; reply sinks -> DeliveryTargets
            / { "DeliverySessions": { transport: transport-id } }                    ; owned-session discovery -> DeliverySessions (wire v10)
            / { "Handover": { session: session-id, target: delivery-target } }      ; re-point Primary -> Ok
            / { "RecordMeta": { session: session-id, origin: origin, kind: tstr, body: bstr } }  ; transport/meta -> Ok
            / { "UnitHistory": { unit: unit-id, after_cursor: uint, max: uint } }
            / { "Pause": { unit: unit-id } }
            / { "Resume": { unit: unit-id } }
            / { "Scale": { unit: unit-id, n: uint } }
            / "VerifyingKey"
            ; ----- runtime control (wire v5): live model switch + §12 edit-approval -----
            / { "SetSessionModel": { session: session-id, model: tstr, ? provider: (any / null) } }   ; model override (overlay) -> Ok
            / { "SetSessionMode": { session: session-id, mode: approval-mode } }                       ; approval override (overlay) -> Ok
            / { "SetSessionOverlay": { session: session-id, overlay: session-overlay } }               ; full per-session overlay -> Ok
            / { "ApprovalsPending": { ? session: (session-id / null) } }                               ; HITL inbox -> Approvals
            / { "ApprovalDecide": { session: session-id, request_id: tstr, allow: bool } }             ; answer + wake -> Ok
            ; ----- profile distributions + versioning (wire v6) -----
            / "ProfileList"                                                                            ; -> Profiles
            / { "ProfileGet": { id: tstr } }                                                           ; -> Profile
            / { "ProfileCreate": { spec: profile-spec } }                                              ; -> ProfileId
            / { "ProfileUpdate": { spec: profile-spec } }                                              ; -> Ok
            / { "ProfileDelete": { id: tstr } }                                                        ; -> Ok
            / { "ProfileSelect": { id: tstr } }                                                        ; -> Ok
            / { "ProfileClone": { source: tstr, new_id: tstr } }                                       ; local copy -> Ok
            / { "ProfileExport": { id: tstr } }                                                        ; -> Distribution
            / { "ProfileImport": { dist: distribution, ? new_id: (tstr / null) } }                     ; -> ProfileId
            / { "ProfileHistory": { id: tstr } }                                                       ; -> Revisions
            / { "ProfileAt": { id: tstr, seq: uint } }                                                 ; -> Profile
            / { "ProfileRevert": { id: tstr, seq: uint } }                                             ; non-destructive -> Ok
            / { "SkillHistory": { name: tstr } }                                                       ; -> Revisions
            / { "SkillAt": { name: tstr, seq: uint } }                                                 ; -> SkillBundle
            / { "SkillRevert": { name: tstr, seq: uint } }                                             ; bundled rejected -> Ok
            / { "CuratorList": { ? profile: (tstr / null) } }                                          ; -> CuratorSkills
            / { "CuratorPin": { ? profile: (tstr / null), name: tstr } }                                ; -> Ok
            / { "CuratorUnpin": { ? profile: (tstr / null), name: tstr } }                              ; -> Ok
            / { "CuratorArchive": { ? profile: (tstr / null), name: tstr } }                            ; -> Ok
            / { "CuratorRestore": { ? profile: (tstr / null), name: tstr } }                            ; -> Ok
            / { "CuratorRun": { ? profile: (tstr / null) } }                                           ; -> CuratorRun
            ; ----- credentials (CredentialApi) -----
            / { "CredentialSet": { profile: tstr, secret: tstr } }                                      ; -> Ok
            / "CredentialList"                                                                         ; -> Credentials
            / { "CredentialRemove": { profile: tstr } }                                                ; -> Ok
            ; ----- model management (ModelApi) -----
            / { "ModelSearch": { query: search-query } }
            / { "ModelFiles": { repo: tstr, revision: (tstr / null), engine: model-engine } }
            / { "ModelDownload": { model: model-ref } }
            / "ModelDownloads"
            / { "ModelCancel": { id: download-id } }
            / { "ModelPause": { id: download-id } }
            / { "ModelResume": { id: download-id } }
            / "ModelCatalog"
            / { "ModelDelete": { id: model-id } }
            / { "ModelActivate": { id: model-id, profile: (tstr / null) } }
            / { "ModelRecommend": { repo: tstr, revision: (tstr / null), engine: model-engine, budget_bytes: (uint / null) } }
            / { "ModelQuantize": { repo: tstr, revision: (tstr / null), target_quant: tstr, source_file: (tstr / null) } }
            / "ModelQuantizes"
            / { "ModelInspect": { id: model-id } }
            / "Models"                                                                                 ; -> Models
            / { "ModelCurrent": { profile: (tstr / null) } }                                           ; -> ModelCurrent
            ; ----- interactive auth (AuthApi), wire v13 -----
            / { "AuthBegin": auth-begin-request }      ; mint authorization URL + park flow -> AuthBegun
            / { "AuthComplete": auth-complete-request } ; finish from captured redirect -> AuthCompleted
            / { "AuthCancel": { flow_id: tstr } }       ; drop a pending flow (idempotent) -> Ok
            / "AuthProviders"                           ; capability discovery -> AuthProviders
            ; ----- §12 checkpoints (rewind points) -----
            / { "CheckpointList": { ? session: (session-id / null) } }                  ; -> Checkpoints
            / { "CheckpointRewind": { session: session-id, checkpoint_id: tstr } }      ; workspace-only rewind -> Ok
            ; ----- GUI roster + unified rewind (wire v14) -----
            / { "SessionsQuery": { query: session-query } }                             ; scoped/paginated roster -> SessionPage
            / { "SessionGet": { session: session-id } }                                 ; one session detail -> SessionDetail
            / "SessionsByProfile"                                                       ; roster grouped by profile -> SessionsByProfile
            / { "SessionSearch": { query: tstr, limit: uint } }                         ; full-text search -> SessionSearch
            / { "SessionUpdateMeta": { session: session-id, patch: session-meta-patch } } ; rename/pin/archive -> Ok
            / { "Rewind": { session: session-id, point: rewind-point } }                ; conversation + workspace rewind -> Ok
            ; ----- ACP discovery/catalog (wire v14) -----
            / "AcpDiscover"                                                             ; trigger a discovery scan -> AcpCatalog
            / "AcpCatalog"                                                              ; persisted catalog -> AcpCatalog
            / { "AcpRegister": { entry: acp-agent-entry } }                             ; register a recipe -> Ok
            / { "AcpRemove": { name: tstr } }                                           ; remove an entry -> Ok
            ; ----- skills (bundle get/put, wire v14) -----
            / { "SkillGet": { name: tstr } }                                            ; -> SkillBundle
            / { "SkillPut": { bundle: skill-bundle } }                                  ; -> Ok
            ; ----- long-tail surfaces (wire v14) -----
            / "ProviderList"                                                            ; -> Providers
            / { "ProviderRegister": { provider: provider-info } }                       ; -> Ok
            / "ToolList"                                                                ; -> Tools
            / { "ToolRegister": { tool: tool-info } }                                   ; -> Ok
            / "CommandList"                                                            ; -> Commands
            / { "CommandInvoke": { invocation: command-invocation } }                   ; -> CommandOutput
            / "ConfigGet"                                                               ; -> Config
            / { "ConfigSet": { config: node-config-view } }                             ; -> Ok
            / "CronList"                                                                ; -> CronJobs
            / { "CronCreate": { spec: cron-spec } }                                     ; -> CronId
            / { "CronUpdate": { id: tstr, spec: cron-spec } }                           ; -> Ok
            / { "CronDelete": { id: tstr } }                                            ; -> Ok
            / { "CronTrigger": { id: tstr } }                                           ; -> Ok
            / { "CronRuns": { id: tstr } }                                              ; -> CronRuns
            ; ----- cron pause/resume + suggestions (wire v15; I15) -----
            / { "CronPause": { id: tstr, paused: bool } }                               ; -> Ok
            / "CronSuggestions"                                                         ; -> CronSuggestions
            / { "CronAcceptSuggestion": { id: tstr } }                                  ; -> CronId
            / { "CronDismissSuggestion": { id: tstr } }                                 ; -> Ok
            ; ----- chat->session routing pins (wire v14; I5, §5.9) -----
            / "RoutingListChats"                                                        ; -> ChatRoutes
            / { "RoutingGet": { origin: origin } }                                      ; -> ChatRoute
            / { "RoutingSet": { route: chat-route } }                                   ; -> Ok
            / { "RoutingBindChat": { origin: origin, session: session-id, ? profile: (profile-ref / null) } }  ; -> Ok
            / { "RoutingUnbindChat": { origin: origin } }                               ; -> Ok
            / { "TransportRooms": { transport: transport-id } }                         ; -> Rooms
            ; ----- filesystem / workspace surface (wire v14; daemon-fs-surface-spec.md) -----
            / "FsRoots"                                                                  ; -> FsRoots
            / { "FsList": { root: fs-root-id, dir: tstr, ? show_ignored: bool } }        ; -> FsList
            / { "FsStat": { root: fs-root-id, path: tstr } }                             ; -> FsStat
            / { "FsRead": { root: fs-root-id, path: tstr, ? max_bytes: uint } }          ; -> FsRead
            / { "FsWrite": { root: fs-root-id, path: tstr, bytes: bstr, ? base_revision: (fs-revision / null), ? force: bool } }  ; -> FsWrite
            / { "FsSearch": { root: fs-root-id, query: fs-search-query } }               ; -> FsSearch
            / { "FsWatchPoll": { root: fs-root-id, dir: tstr, after_seq: uint, max: uint } }  ; cursor read -> FsWatch
            ; ----- content store (wire v14; daemon-content-transfer-spec.md) -----
            / { "BlobPut": { bytes: bstr } }                                             ; -> BlobPut
            / { "BlobGet": { hash: content-hash, ? range: (byte-range / null) } }        ; -> BlobGet
            / { "BlobStat": { hash: content-hash } }                                     ; -> BlobStat
            / { "FsWriteFromBlob": { root: fs-root-id, path: tstr, hash: content-hash, ? base_revision: (fs-revision / null), ? force: bool } }  ; -> FsWrite

api-response = "Ok"
             / { "Routed": { session: session-id } }   ; the session a SubmitRouted resolved to (wire v7)
             / { "Drained": [* outbound] }
             / { "Health": health-report }
             / { "Stats": stats-report }
             / { "Telemetry": any }
             / { "Sessions": [* session-info] }
             / { "Approvals": [* approval-info] }
             / { "Fleet": fleet-report }
             / { "Tree": tree-report }
             / { "Unit": (unit-node / null) }
             / { "UnitEvents": [* manage-event-view] }
             / { "Journal": journal-page-view }
             / { "LogPage": log-page-view }
             / { "DeliveryTargets": [* delivery-target] }
             / { "DeliverySessions": [* session-id] }   ; owned sessions of a transport instance (wire v10)
             / { "VerifyingKey": (tstr / null) }
             / { "ModelSearch": search-page }
             / { "ModelFiles": [* model-file] }
             / { "ModelDownloadStarted": download-id }
             / { "ModelDownloads": [* download-status] }
             / { "ModelCatalog": [* installed-model] }
             / { "ModelRecommend": quant-recommendation }
             / { "ModelQuantizeStarted": quantize-id }
             / { "ModelQuantizes": [* quantize-status] }
             / { "ModelInspect": gguf-info }
             / { "Profiles": [* profile-info] }
             / { "Profile": (profile-spec / null) }
             / { "Credentials": [* credential-info] }
             / { "Models": [* model-descriptor] }
             / { "ModelCurrent": (model-descriptor / null) }
             ; ----- profile distributions + versioning (wire v6) -----
             / { "Distribution": distribution }
             / { "ProfileId": tstr }
             / { "Revisions": [* revision] }
             / { "SkillBundle": skill-bundle }
             / { "CuratorSkills": [* curator-entry] }
             / { "CuratorRun": [* curator-change] }
             ; ----- interactive auth (AuthApi), wire v13 -----
             / { "AuthBegun": auth-begin-response }
             / { "AuthCompleted": auth-complete-response }
             / { "AuthProviders": [* auth-provider-info] }
             ; ----- §12 checkpoints + GUI roster + unified rewind (wire v14) -----
             / { "Checkpoints": [* checkpoint-info] }
             / { "SessionPage": session-page }
             / { "SessionDetail": (session-detail / null) }
             / { "SessionsByProfile": [* [profile-ref, [* session-info]]] }
             / { "SessionSearch": [* session-search-hit] }
             ; ----- ACP discovery/catalog (wire v14) -----
             / { "AcpCatalog": [* acp-agent-entry] }
             ; ----- long-tail surfaces (wire v14) -----
             / { "Providers": [* provider-info] }
             / { "Tools": [* tool-info] }
             / { "Commands": [* command-spec] }
             / { "CommandOutput": command-output }
             / { "Config": node-config-view }
             / { "CronJobs": [* cron-job] }
             / { "CronId": tstr }
             / { "CronRuns": [* cron-run] }
             / { "CronSuggestions": [* cron-suggestion] }   ; wire v15 (I15)
             ; ----- chat->session routing pins (wire v14; I5, §5.9) -----
             / { "ChatRoutes": [* chat-route] }
             / { "ChatRoute": (chat-route / null) }
             / { "Rooms": [* room-info] }
             / { "Error": api-error }
             ; ----- filesystem / workspace surface (wire v14) -----
             / { "FsRoots": [* fs-root] }
             / { "FsList": [* fs-entry] }
             / { "FsStat": fs-entry }
             / { "FsRead": fs-content }
             / { "FsWrite": fs-revision }
             / { "FsSearch": fs-search-page }
             / { "FsWatch": fs-watch-page-view }
             ; ----- content store (wire v14) -----
             / { "BlobPut": blob-ref }
             / { "BlobGet": bstr }
             / { "BlobStat": blob-stat }

; ----- filesystem / workspace surface DTOs (wire v14; daemon-fs-surface-spec.md) -----
fs-root-id = { "host": tstr } / "workspace" / { "session": session-id }
fs-root-kind = "host" / "workspace" / "session"
fs-root = { id: fs-root-id, label: tstr, kind: fs-root-kind, ? session: (session-id / null) }
fs-entry-kind = "file" / "dir" / "symlink"
fs-entry = { name: tstr, path: tstr, kind: fs-entry-kind, size: uint, mtime_ms: uint, ? ignored: bool }
fs-revision = { mtime_ms: uint, size: uint }
fs-content = { bytes: bstr, revision: fs-revision, ? truncated: bool, ? blob_ref: (blob-ref / null) }
fs-search-query = { query: tstr, ? regex: bool, ? case_sensitive: bool, ? max_results: uint, ? page: uint }
fs-search-hit = { path: tstr, line: uint, col: uint, preview: tstr }
fs-search-page = { hits: [* fs-search-hit], ? has_more: bool }
fs-change-kind = "created" / "modified" / "removed"
fs-change = { path: tstr, kind: fs-change-kind }
fs-watch-page-view = { events: [* fs-change], next_seq: uint }

; ----- content store DTOs (wire v14; daemon-content-transfer-spec.md) -----
content-hash = bstr                 ; 32-byte SHA-256 (mirrors revision.content_hash)
byte-range = { offset: uint, len: uint }
blob-ref = { hash: content-hash, size: uint, ? name: (tstr / null), ? mime: (tstr / null) }
blob-stat = { size: uint, present: bool }
