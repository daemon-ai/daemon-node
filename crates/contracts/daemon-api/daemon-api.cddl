request-member-invite = { "MemberInvite": member-invite-args }
member-remove-args = { "transport": transport-id, "conv": tstr, "who": participant, ? "reason": (tstr / null) }
request-member-remove = { "MemberRemove": member-remove-args }
member-ban-args = { "transport": transport-id, "conv": tstr, "who": participant, ? "reason": (tstr / null) }
