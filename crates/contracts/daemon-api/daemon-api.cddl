request-conv-join-details = { "ConvJoinDetails": { "transport": transport-id } }
request-conv-join = { "ConvJoin": { "transport": transport-id, "details": channel-join-details } }
request-conv-leave = { "ConvLeave": { "transport": transport-id, "conv": tstr } }
