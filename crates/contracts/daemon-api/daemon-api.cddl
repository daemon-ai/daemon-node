request-auth-step = { "AuthStep": auth-step-request }
request-auth-complete = { "AuthComplete": auth-complete-request }
request-auth-cancel = { "AuthCancel": { "flow_id": tstr } }
request-auth-providers = "AuthProviders"
request-checkpoint-list = { "CheckpointList": { ? "session": (session-id / null), ? "after": (tstr / null) } }
request-checkpoint-rewind = { "CheckpointRewind": { "session": session-id, "checkpoint_id": tstr } }
request-sessions-query = { "SessionsQuery": { "query": session-query } }
