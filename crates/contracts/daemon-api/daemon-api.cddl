response-action-menu = { "ActionMenu": (action-menu / null) }
response-error = { "Error": api-error }
response-fs-roots = { "FsRoots": [* fs-root] }
response-fs-list = { "FsList": fs-list-page }
response-fs-stat = { "FsStat": fs-entry }
response-fs-read = { "FsRead": fs-content }
response-fs-write = { "FsWrite": fs-revision }
response-fs-search = { "FsSearch": fs-search-page }
response-fs-watch = { "FsWatch": fs-watch-page-view }
response-blob-put = { "BlobPut": blob-ref }
response-blob-get = { "BlobGet": byte-array }
response-blob-stat = { "BlobStat": blob-stat }

; ----- access control (Auth 5) DTOs + responses -----
; access-user mirrors daemon_auth::UserRecord + resolved roles; carries NO credential material.
access-user = { "user_id": tstr, "username": tstr, "disabled": bool, "created_at": int, "roles": [* tstr] }
role-info   = { "role": tstr, "capabilities": [* tstr] }
response-access-user  = { "AccessUser": access-user }
response-access-users = { "AccessUsers": [* access-user] }
response-access-roles = { "AccessRoles": [* role-info] }
response-who-am-i     = { "WhoAmI": principal-view }

; ----- user feedback over OpenTelemetry (N1; wire v32) -----
feedback-ack = { "accepted": bool, "queued": bool }
response-feedback-ack = { "FeedbackAck": feedback-ack }
response-telemetry-consent = { "TelemetryConsent": { "enabled": bool } }
