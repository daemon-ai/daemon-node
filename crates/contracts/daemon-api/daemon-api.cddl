request-session-update-meta = { "SessionUpdateMeta": { "session": session-id, "patch": session-meta-patch } }
request-rewind = { "Rewind": { "session": session-id, "point": rewind-point } }
request-agent-discover = "AgentDiscover"
request-agent-catalog = "AgentCatalog"
