; ----- access control (Auth 5): admin user/role/session management -----
; `password` is a request-only input; it never appears in any response or audit payload.
request-user-create        = { "UserCreate": { "username": tstr, "password": tstr, "roles": [* tstr] } }
request-user-list          = "UserList"
request-user-disable       = { "UserDisable": { "user_id": tstr, "disabled": bool } }
request-user-set-roles     = { "UserSetRoles": { "user_id": tstr, "roles": [* tstr] } }
request-user-set-password  = { "UserSetPassword": { "user_id": tstr, "password": tstr } }
request-role-list          = "RoleList"
request-who-am-i           = "WhoAmI"
request-session-revoke     = { "SessionRevoke": { "user_id": tstr } }
request-resource-grant-create = { "ResourceGrantCreate": { "user_id": tstr, "resource_kind": tstr, "resource_id": tstr, "capability": tstr } }
request-resource-grant-list   = { "ResourceGrantList": { ? "user_id": (tstr / null) } }
request-resource-grant-revoke = { "ResourceGrantRevoke": { "id": tstr } }

; ----- user feedback over OpenTelemetry (N1; wire v32) -----
; Explicit feedback is per-event consent (queued even when the global telemetry toggle is off);
; the ack means accepted+queued to the durable outbox, never delivered. Optional fields mirror
; serde `#[serde(default)] Option<T>` as `? "k": (T / null)`.
feedback-kind = "response" / "app"
feedback-rating = "up" / "down"
feedback-target = { "session": session-id, "cursor": uint64, ? "trace": (trace-id / null) }
feedback-diagnostics = { ? "app_version": (tstr / null), ? "os": (tstr / null) }
request-feedback-submit = { "FeedbackSubmit": { "kind": feedback-kind, ? "target": (feedback-target / null), ? "rating": (feedback-rating / null), ? "comment": (tstr / null), "include_content": bool, ? "diagnostics": (feedback-diagnostics / null), "surface": tstr } }
request-telemetry-consent-get = "TelemetryConsentGet"
request-telemetry-consent-set = { "TelemetryConsentSet": { "enabled": bool } }

