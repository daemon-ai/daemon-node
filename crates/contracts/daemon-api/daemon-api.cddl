request-credential-remove = { "CredentialRemove": { "profile": tstr } }
request-credential-set-label = { "CredentialSetLabel": { "profile": tstr, ? "label": (tstr / null) } }
request-model-search = { "ModelSearch": { "query": search-query } }
request-model-files = { "ModelFiles": { "repo": tstr, "revision": (tstr / null), "engine": model-engine, ? "after": (tstr / null) } }
