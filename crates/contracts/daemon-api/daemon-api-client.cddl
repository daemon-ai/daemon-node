; daemon-api-client.cddl — the client view of daemon-api, in zcbor-generatable form.
;
; This is the same wire contract as daemon-api.cddl (the authoritative full mirror), restricted to
; the api-request/api-response variants the GUI/TUI client exercises and rewritten in zcbor's dialect
; (quoted map keys, no `any`). It exists only because the full daemon-api.cddl is not yet
; zcbor-generatable (barewords + `any` + unions-of-single-key-maps); the goal is to converge on one
; file. `xtask cddl` keeps the full mirror complete; `xtask verify-codec` proves this subset stays
; byte-compatible with the serde wire format.

session-id = tstr
profile-ref = tstr
req-id = uint

user-msg = { "text": tstr, ? "attachments": [* blob-ref] }
blob-ref = { "hash": bstr, "size": uint }

agent-command-start-turn = { "StartTurn": { "input": user-msg, "request_id": req-id } }
agent-command-steer = { "Steer": { "text": tstr, "request_id": req-id } }
agent-command-shutdown = "Shutdown"
agent-command = agent-command-start-turn
              / agent-command-steer
              / agent-command-shutdown

service-health = {
  "name": tstr,
  "ok": bool,
  "restarts": uint,
  "detail": (tstr / null),
}

health-report = {
  "all_ok": bool,
  "services": [* service-health],
}

session-state = "Active" / "Ready" / "Completed" / "Unknown"
lifecycle = "Durable" / "Live"
session-role = "Primary" / "ManagedChild" / "EphemeralSubagent"

session-info = {
  "session": session-id,
  "state": session-state,
  ? "bound_profile": (profile-ref / null),
  ? "title": (tstr / null),
  ? "lifecycle": lifecycle,
  ? "role": session-role,
  ? "parent": (session-id / null),
  ? "pinned": bool,
  ? "archived": bool,
}

session-scope = "TopLevel" / { "ByProfile": profile-ref } / "Archived" / "All"
session-query = {
  ? "scope": session-scope,
  ? "after": (session-id / null),
  ? "limit": uint,
}

session-page = {
  "sessions": [* session-info],
  ? "next_cursor": (session-id / null),
}

direction = "Inbound" / "Outbound"
disposition = "Context" / "Transport"
; NOTE: `scope` is simplified to tstr here. The real daemon-api origin-scope is a union of single-key
; maps (Dm/Group/Api/Internal); zcbor collides on the generated helper names for that pattern under
; our codegen flags, and the only tested fixture carries origin=null, so the map shape is unexercised.
; Modeling the full origin-scope is part of growing this subset toward the full daemon-api.cddl.
origin = { "transport": tstr, "scope": tstr }
session-payload = { "Command": agent-command }
session-log-entry = {
  "seq": uint,
  "direction": direction,
  "origin": origin,
  "disposition": disposition,
  "payload": session-payload,
}
log-page-view = {
  "entries": [* session-log-entry],
  "next_seq": uint,
  "head_seq": uint,
}

fs-root-id = tstr
fs-root-kind = tstr
fs-root = { "id": fs-root-id, "label": tstr, "kind": fs-root-kind, ? "session": (session-id / null) }

; command catalog (thin-client slash-command surface)
command-scope = "Session" / "Node"
command-surface = "Cli" / "Gui" / "Chat"
command-access = "User" / "Admin"
command-spec = {
  "name": tstr,
  "aliases": [* tstr],
  "summary": tstr,
  "category": tstr,
  "args_hint": tstr,
  "subcommands": [* tstr],
  "scope": command-scope,
  "surfaces": [* command-surface],
  "side_effecting": bool,
  "confirm": bool,
  "min_access": command-access,
  "source": tstr,
}
command-invocation = {
  "name": tstr,
  "args": tstr,
  "session": (session-id / null),
  "origin": (origin / null),
}
command-output = { "text": tstr, "ephemeral": bool }

request-health = "Health"
request-sessions-query = { "SessionsQuery": { "query": session-query } }
request-subscribe = { "Subscribe": { "session": session-id, "after_seq": uint, "max": uint } }
request-submit = { "Submit": { "session": session-id, "command": agent-command, ? "origin": (origin / null), ? "profile": (profile-ref / null) } }
request-profile-list = "ProfileList"
request-model-current = { "ModelCurrent": { "profile": (tstr / null) } }
request-fs-roots = "FsRoots"
request-command-list = "CommandList"
request-command-invoke = { "CommandInvoke": { "invocation": command-invocation } }

api-request = request-health
            / request-sessions-query
            / request-subscribe
            / request-submit
            / request-profile-list
            / request-model-current
            / request-fs-roots
            / request-command-list
            / request-command-invoke

response-health = { "Health": health-report }
response-session-page = { "SessionPage": session-page }
response-log-page = { "LogPage": log-page-view }
response-fs-roots = { "FsRoots": [* fs-root] }
response-commands = { "Commands": [* command-spec] }
response-command-output = { "CommandOutput": command-output }
response-ok = "Ok"
; NOTE: the `Error` arm ({ "Error": api-error }) is intentionally omitted. api-error is a union of
; single-key maps ({"UnknownSession": tstr} / {"Unsupported": tstr} / ...), which trips the same zcbor
; helper-name collision (decode_repeated_api_error_map) as origin-scope. It blocks daemon-app's
; codec-error-surface; unblocking needs the zcbor union-of-single-key-maps workaround (tracked with
; the cddl-growth effort), not just a fixture.

api-response = response-health
             / response-session-page
             / response-log-page
             / response-fs-roots
             / response-commands
             / response-command-output
             / response-ok
